SERVER_PORT=8001
JWT_SECRET=change_me

# WeChat Mini Program login
WECHAT_APPID=
WECHAT_SECRET=

# WeChat Pay API v3 / JSAPI
WECHAT_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/pay/wechat/notify
WECHAT_PAY_PRIVATE_KEY_PATH=/absolute/path/to/apiclient_key.pem
# Optional alternative to WECHAT_PAY_PRIVATE_KEY_PATH:
# WECHAT_PAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Required for payment notify signature verification
WECHAT_PAY_PLATFORM_CERT_PATH=/absolute/path/to/wechatpay_platform_cert.pem
# Optional alternative to WECHAT_PAY_PLATFORM_CERT_PATH:
# WECHAT_PAY_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

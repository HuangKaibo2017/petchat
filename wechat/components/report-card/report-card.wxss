.report-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 0 32rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.report-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 28rpx;
}
.report-icon.emotion { background: #E8F5F0; }
.report-icon.health { background: #DBEAFE; }
.report-icon.risk { background: #FEE2E2; }
.report-icon.medical { background: #D1FAE5; }
.report-summary {
  color: #374151;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}
.action-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 8rpx;
}
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-low { background: #F0FDF4; color: #22C55E; }
.tag-medium { background: #FFFBEB; color: #F59E0B; }
.tag-high { background: #FEF2F2; color: #EF4444; }
.tag-success { background: #F0FDF4; color: #22C55E; }

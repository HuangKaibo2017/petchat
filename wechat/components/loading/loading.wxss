.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #F3F4F6;
  border-top-color: #2D7D6E;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}
.loading-text { margin-top: 24rpx; }

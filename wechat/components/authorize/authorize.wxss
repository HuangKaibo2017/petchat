.auth-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
.auth-dialog {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  margin: 0 48rpx;
  text-align: center;
  width: 560rpx;
}
.auth-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}
.auth-title {
  margin-bottom: 16rpx;
  color: #F97316;
}
.auth-desc {
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.auth-cancel {
  margin-top: 24rpx;
}

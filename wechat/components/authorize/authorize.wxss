.auth-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
.auth-dialog {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  margin: 0 48rpx;
  text-align: center;
  width: 560rpx;
}
.auth-title {
  margin-bottom: 12rpx;
  color: var(--color-text-primary);
}
.auth-desc {
  margin-bottom: 40rpx;
  line-height: 1.5;
}

/* 头像选择按钮 */
.avatar-picker {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0 auto 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: auto;
  line-height: 1;
}
.avatar-picker::after {
  border: none;
}
.avatar-preview {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ECEAE5;
  margin-bottom: 12rpx;
}
.avatar-hint {
  color: var(--color-text-hint);
}

/* 昵称输入 */
.nickname-input-wrap {
  margin-bottom: 32rpx;
}
.nickname-input {
  background: var(--color-bg-gray);
  border-radius: var(--radius-md);
  padding: 20rpx 24rpx;
  font-size: var(--font-md);
  text-align: center;
  color: var(--color-text-primary);
}

.auth-cancel {
  margin-top: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}
.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.6;
}
.empty-title {
  color: #9CA3AF;
  margin-bottom: 8rpx;
}
.empty-desc {
  max-width: 400rpx;
  text-align: center;
}

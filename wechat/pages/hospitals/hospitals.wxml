<nav-bar title="合作医院" showBack="{{true}}" />
<view class="page-container">
  <view class="search-bar px-md py-sm">
    <view class="search-input flex items-center">
      <text class="text-hint mr-sm">🔍</text>
      <input placeholder="搜索医院名称" bindinput="onSearch" />
    </view>
  </view>
  <view class="filter-row flex px-md py-sm">
    <view class="filter-chip active">距离最近</view>
    <view class="filter-chip">评分最高</view>
    <view class="filter-chip">支持直付</view>
    <view class="filter-chip">24小时</view>
  </view>
  <view class="hospital-list">
    <view class="hospital-card card flex" wx:for="{{hospitals}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image class="hospital-img" src="{{item.image || '/images/default-hospital.png'}}" mode="aspectFill" />
      <view class="ml-md flex-1">
        <view class="text-md font-bold">{{item.name}}</view>
        <view class="flex items-center mt-sm">
          <text class="text-warning text-sm">⭐ {{item.rating}}</text>
          <text class="text-hint text-xs ml-sm">{{item.distance}}</text>
        </view>
        <view class="flex mt-sm">
          <text class="tag tag-primary text-xs" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="t">{{t}}</text>
        </view>
        <view class="text-xs text-hint mt-sm">{{item.address}}</view>
      </view>
      <view class="text-primary text-sm">›</view>
    </view>
  </view>
</view>

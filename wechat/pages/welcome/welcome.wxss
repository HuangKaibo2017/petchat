/* ═══════════════════════════════════════════
   Welcome Page — 更懂它 微信登录页
   ═══════════════════════════════════════════ */

.welcome-page {
  min-height: 100vh;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* ─── 背景 ─── */
.welcome-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg, #2D7D6E 0%, #1A5A4E 30%, #0F3D35 60%, #0A2A24 100%);
  z-index: 0;
}
.welcome-bg::after {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle at 30% 40%, rgba(139,92,246,0.15) 0%, transparent 50%),
              radial-gradient(circle at 70% 60%, rgba(249,115,22,0.10) 0%, transparent 50%);
  animation: bgPulse 8s ease-in-out infinite;
}
@keyframes bgPulse {
  0%, 100% { opacity: 0.6; }
  50% { opacity: 1; }
}

/* ─── 主体 ─── */
.welcome-body {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 64rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ─── Logo ─── */
.welcome-logo-area {
  text-align: center;
  margin-bottom: 80rpx;
}
.welcome-logo {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: logoFloat 3s ease-in-out infinite;
}
@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
.welcome-brand {
  font-size: 56rpx;
  font-weight: 800;
  color: #FFFFFF;
  letter-spacing: 12rpx;
  margin-bottom: 12rpx;
}
.welcome-slogan {
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
  letter-spacing: 6rpx;
}

/* ─── 操作区 ─── */
.welcome-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.welcome-btn-primary {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7,193,96,0.3);
  transition: all 0.2s;
}
.welcome-btn-primary::after { border: none; }
.welcome-btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.welcome-desc {
  font-size: 22rpx;
  color: rgba(255,255,255,0.45);
  text-align: center;
  line-height: 1.6;
}
.welcome-desc .link {
  color: rgba(255,255,255,0.65);
}
.welcome-guest {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  padding: 12rpx 0;
}

/* ─── NFC 区域 ─── */
.welcome-nfc-area {
  position: relative;
  padding: 48rpx 64rpx;
  margin-bottom: 64rpx;
  text-align: center;
  border-radius: 32rpx;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255,255,255,0.12);
}
.nfc-glow {
  position: absolute;
  inset: -2rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, rgba(249,115,22,0.3), rgba(139,92,246,0.3), rgba(45,125,110,0.3));
  filter: blur(20rpx);
  opacity: 0.5;
  animation: glowPulse 2s ease-in-out infinite;
}
@keyframes glowPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.6; }
}
.nfc-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}
.nfc-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
  position: relative;
  z-index: 1;
}
.nfc-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 6rpx;
  position: relative;
  z-index: 1;
}

/* ─── 底部 ─── */
.welcome-footer {
  position: absolute;
  bottom: 80rpx;
  z-index: 1;
}

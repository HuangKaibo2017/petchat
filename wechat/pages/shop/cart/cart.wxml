<nav-bar title="购物车" showBack="{{true}}" />
<view class="page-container">
  <view class="cart-item card flex items-center" wx:for="{{cart}}" wx:key="cartId">
    <image class="cart-img" src="{{item.image}}" mode="aspectFill" />
    <view class="ml-md flex-1">
      <view class="text-sm font-bold">{{item.name}}</view>
      <view class="text-primary font-bold mt-sm">¥{{item.price}}</view>
    </view>
    <view class="text-danger" bindtap="removeItem" data-id="{{item.cartId}}">删除</view>
  </view>
  <empty-state wx:if="{{!cart.length}}" title="购物车空空如也" desc="去商城逛逛吧" actionText="去商城" bind:action="goShop" />
  <view class="cart-bar safe-bottom" wx:if="{{cart.length}}">
    <view class="flex-1"><text class="text-sm">合计：</text><text class="text-primary text-xl font-bold">¥{{totalPrice}}</text></view>
    <button class="btn btn-primary btn-sm" bindtap="checkout">去结算</button>
  </view>
</view>

<nav-bar title="商品详情" showBack="{{true}}" />
<view class="page-container">
  <image class="detail-img" src="{{product.image}}" mode="aspectFill" />
  <view class="detail-info card">
    <view class="text-xl font-bold">{{product.name}}</view>
    <view class="text-xs text-hint mt-sm">{{product.desc}}</view>
    <view class="flex-between mt-md">
      <view class="text-primary font-bold text-2xl">¥{{product.price}}</view>
      <view class="text-xs text-hint">已售 1000+</view>
    </view>
  </view>
  <view class="detail-section card">
    <view class="text-md font-bold mb-sm">商品详情</view>
    <view class="text-sm text-muted">灵犀NFC项圈，专为宠物设计。内置NFC芯片，扫码即可查看宠物档案、健康报告。防水设计，续航长达6个月。</view>
  </view>
  <view class="detail-section card">
    <view class="text-md font-bold mb-sm">合规提示</view>
    <view class="text-xs text-hint">本品为非药品类商品，如有健康问题请及时就医。</view>
  </view>
  <view style="height: 140rpx"></view>
  <view class="detail-bar safe-bottom">
    <view class="flex items-center" bindtap="goCart"><text class="text-lg">🛒</text><text class="text-xs ml-sm">购物车</text></view>
    <button class="btn btn-outline btn-sm flex-1" bindtap="addToCart">加入购物车</button>
    <button class="btn btn-primary btn-sm flex-1" bindtap="buyNow" style="margin-left:16rpx">立即购买</button>
  </view>
</view>

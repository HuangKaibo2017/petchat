.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 160rpx;
}

/* ─── 商品主图 ─── */
.detail-image-wrap {
  width: 100%;
  height: 560rpx;
  background: var(--color-bg-gray);
}

.detail-image {
  width: 100%;
  height: 100%;
}

/* ─── 商品信息卡片 ─── */
.detail-info {
  margin: 24rpx 32rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.detail-desc {
  font-size: 26rpx;
  color: var(--color-text-hint);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.detail-price-row {
  display: flex;
  align-items: baseline;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.detail-price {
  font-size: 48rpx;
  font-weight: 700;
  color: #E8443A;
}

/* ─── 购买按钮 ─── */
.detail-action {
  padding: 0 32rpx;
  margin-top: 32rpx;
}

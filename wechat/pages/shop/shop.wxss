.search-bar { background: #FFFFFF; }
.search-input { background: #F3F4F6; border-radius: 9999rpx; padding: 16rpx 24rpx; }

/* 营销入口 */
.promo-strip { display: flex; gap: 12rpx; padding: 16rpx 0; background: #FFFFFF; }
.promo-item { flex: 1; display: flex; align-items: center; gap: 10rpx; padding: 16rpx 14rpx; border-radius: 16rpx; background: #F9FAFB; }
.promo-icon { font-size: 32rpx; }
.promo-text { flex:1; }
.promo-flash { background: linear-gradient(135deg, #FEF2F2, #FFF7ED); }
.promo-group { background: linear-gradient(135deg, #EFF6FF, #F0FDF4); }
.promo-coupon { background: linear-gradient(135deg, #FEFCE8, #FEF3C7); }
.promo-countdown { }
.promo-badge { }

/* 品类 */
.category-scroll { white-space: nowrap; padding: 16rpx 0; background: #FFFFFF; }
.category-item { display: inline-block; padding: 12rpx 24rpx; margin-right: 12rpx; background: #F3F4F6; border-radius: 9999rpx; font-size: 26rpx; color: #6B7280; }
.category-item.active { background: #D8EBE6; color: #2D7D6E; font-weight: 600; }

/* 商品网格 */
.product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 16rpx; }
.product-card { background: #FFFFFF; border-radius: 20rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.product-img-wrap { position: relative; }
.product-card-img { width: 100%; height: 280rpx; }
.product-card-info { padding: 16rpx; }

/* 自营/商家标识 */
.shop-badge { position: absolute; top: 12rpx; left: 12rpx; padding: 4rpx 14rpx; border-radius: 8rpx; font-size: 20rpx; font-weight: 600; }
.badge-self { background: #D8EBE6; color: #2D7D6E; }
.badge-merchant { background: #EDE9FE; color: #7C3AED; }

/* 秒杀/拼团标 */
.flash-tag { position: absolute; top: 12rpx; right: 12rpx; padding: 4rpx 12rpx; border-radius: 8rpx; background: #FEE2E2; color: #EF4444; font-size: 20rpx; font-weight: 600; }
.group-tag { position: absolute; top: 12rpx; right: 12rpx; padding: 4rpx 12rpx; border-radius: 8rpx; background: #DBEAFE; color: #2563EB; font-size: 20rpx; font-weight: 600; }

/* 标签 */
.tag { display:inline-flex; align-items:center; padding:4rpx 16rpx; border-radius:9999rpx; font-size:22rpx; font-weight:500; }
.tag-warning { background:#FFFBEB; color:#F59E0B; }

/* 购物车 */
.cart-btn { font-size: 36rpx; }
.cart-float { position: fixed; bottom: 140rpx; right: 32rpx; z-index: 100; }
.cart-icon-wrap { position: relative; width: 96rpx; height: 96rpx; background: #2D7D6E; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.4); }
.badge { position: absolute; top: -4rpx; right: -4rpx; min-width: 32rpx; height: 32rpx; background: #EF4444; border-radius: 50%; color: #FFFFFF; font-size: 20rpx; display: flex; align-items: center; justify-content: center; }

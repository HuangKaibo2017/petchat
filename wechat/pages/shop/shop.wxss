.shop-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ─── 悬浮购物车按钮 ─── */
.shop-float-cart {
  position: fixed;
  right: 32rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  z-index: 50;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: var(--color-primary);
  box-shadow: 0 8rpx 28rpx rgba(45, 125, 110, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.shop-float-cart:active {
  transform: scale(0.92);
}

.shop-float-icon {
  width: 48rpx;
  height: 48rpx;
}

.shop-float-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  background: #E8443A;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 3rpx solid #FFFFFF;
}

/* ─── 分类标签 ─── */
.shop-cats {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 32rpx;
  gap: 16rpx;
  background: #FFFFFF;
}

.shop-cat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 60rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  border-radius: 30rpx;
  flex-shrink: 0;
}

.shop-cat--active {
  color: #FFFFFF;
  background: var(--color-primary);
}

/* ─── 商品网格 ─── */
.shop-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 24rpx;
  gap: 20rpx;
}

.shop-card {
  width: calc(50% - 10rpx);
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
}

.shop-card-img-wrap {
  position: relative;
  width: 100%;
  height: 320rpx;
  background: var(--color-bg);
}

.shop-card-swiper {
  width: 100%;
  height: 100%;
}

.shop-card-img {
  width: 100%;
  height: 100%;
}

.shop-card-category {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 20rpx;
  background: rgba(0, 0, 0, 0.56);
  color: #FFFFFF;
  font-size: 22rpx;
  line-height: 40rpx;
}

.shop-card-info {
  padding: 14rpx 16rpx 16rpx;
}

.shop-card-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.35;
}

.shop-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.shop-card-price {
  color: #E8443A;
  font-size: 32rpx;
  font-weight: 700;
}

/* ─── 空状态 ─── */
.shop-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.shop-empty-text {
  font-size: 28rpx;
  color: var(--color-text-hint);
}

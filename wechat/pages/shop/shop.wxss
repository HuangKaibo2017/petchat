.search-bar { background: #FFFFFF; }
.search-input { background: #F3F4F6; border-radius: 9999rpx; padding: 16rpx 24rpx; }

.category-scroll { white-space: nowrap; padding: 16rpx 0; background: #FFFFFF; }
.category-item {
  display: inline-block; padding: 12rpx 24rpx; margin-right: 12rpx;
  background: #F3F4F6; border-radius: 9999rpx; font-size: 26rpx; color: #6B7280;
}
.category-item.active { background: #D8EBE6; color: #2D7D6E; font-weight: 600; }

.product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 16rpx; }
.product-card { background: #FFFFFF; border-radius: 20rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.product-card-img { width: 100%; height: 280rpx; }
.product-card-info { padding: 16rpx; }
.cart-btn { font-size: 36rpx; }

.cart-float { position: fixed; bottom: 140rpx; right: 32rpx; z-index: 100; }
.cart-icon-wrap {
  position: relative; width: 96rpx; height: 96rpx;
  background: #2D7D6E; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.4);
}
.badge { position: absolute; top: -4rpx; right: -4rpx; min-width: 32rpx; height: 32rpx; background: #EF4444; border-radius: 50%; color: #FFFFFF; font-size: 20rpx; display: flex; align-items: center; justify-content: center; }

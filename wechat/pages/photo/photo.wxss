/* ═══════════════════════════════════════════
   Photo Page — 宠物影像
   ═══════════════════════════════════════════ */
.page-container { padding-bottom: 48rpx; }

.mode-intro {
  margin: 16rpx 32rpx 24rpx;
  padding: 32rpx 24rpx;
  text-align: center;
  background: linear-gradient(180deg, #FAF9F5, #FFFFFF);
}
.mode-icon { font-size: 56rpx; margin-bottom: 16rpx; }
.mode-title { color: #1F2937; }
.mode-desc { line-height: 1.6; }

.photo-upload-area {
  margin: 0 32rpx;
  width: calc(100vw - 64rpx);
  height: 400rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #F9FAFB;
  border: 2rpx dashed #D1D5DB;
}
.upload-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9CA3AF;
}
.preview-img {
  width: 100%;
  height: 100%;
}

.input-area {
  margin: 0 32rpx;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.watermark-input {
  width: 100%;
  font-size: 30rpx;
  color: #1F2937;
  padding: 8rpx 0;
}

.result-img {
  width: 100%;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  padding: 0 32rpx;
}
.photo-grid-item {
  position: relative;
  aspect-ratio: 1;
  border-radius: 16rpx;
  overflow: hidden;
  background: #F3F4F6;
}
.grid-img {
  width: 100%;
  height: 100%;
}
.grid-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}
.photo-add {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9CA3AF;
  border: 2rpx dashed #D1D5DB;
}

.section { margin-bottom: 32rpx; }
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin: 0 32rpx 16rpx;
}

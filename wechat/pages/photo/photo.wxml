<nav-bar title="{{pageTitle}}" showBack="{{true}}" />
<view class="page-container">
  <!-- 模式介绍 -->
  <view class="mode-intro card">
    <view class="mode-icon">{{modeEmoji}}</view>
    <view class="mode-title text-xl font-bold">{{modeIntro.title}}</view>
    <view class="mode-desc text-sm text-hint mt-sm">{{modeIntro.desc}}</view>
  </view>

  <!-- 水印照片模式 -->
  <block wx:if="{{mode==='watermark'}}">
    <view class="section">
      <view class="section-title">选择照片</view>
      <view class="photo-upload-area" bindtap="choosePhoto">
        <image class="preview-img" src="{{photoPath || '/images/empty-default.png'}}" mode="aspectFill" wx:if="{{photoPath}}" />
        <view class="upload-placeholder" wx:else>
          <text class="text-5xl">📷</text>
          <text class="text-sm text-hint mt-md">点击选择宠物照片</text>
        </view>
      </view>
    </view>
    <view class="section" wx:if="{{photoPath}}">
      <view class="section-title">输入一句话 <text class="text-xs text-hint">· 20字以内</text></view>
      <view class="input-area">
        <input class="watermark-input" placeholder="例如：你是我的小太阳" maxlength="{{20}}" value="{{watermarkText}}" bindinput="onTextInput" />
        <view class="text-xs text-hint text-right mt-xs">{{watermarkText.length}}/20</view>
      </view>
    </view>
    <view class="section" wx:if="{{photoPath}}">
      <view class="btn btn-primary btn-block" bindtap="generateWatermark">🖼️ 生成水印照片</view>
    </view>
    <view class="section" wx:if="{{watermarkedImage}}">
      <view class="section-title">预览</view>
      <image class="result-img" src="{{watermarkedImage}}" mode="widthFix" />
      <view class="btn btn-outline btn-block mt-md" bindtap="saveWatermark">💾 保存到相册</view>
    </view>
  </block>

  <!-- 日记漫画模式 -->
  <block wx:if="{{mode==='comic'}}">
    <view class="section">
      <view class="section-title">选择6张以上照片</view>
      <view class="photo-grid">
        <view class="photo-grid-item" wx:for="{{comicPhotos}}" wx:key="index">
          <image class="grid-img" src="{{item}}" mode="aspectFill" />
          <view class="grid-remove" catchtap="removeComicPhoto" data-index="{{index}}">✕</view>
        </view>
        <view class="photo-grid-item photo-add" bindtap="chooseComicPhoto" wx:if="{{comicPhotos.length < 12}}">
          <text class="text-4xl">+</text>
        </view>
      </view>
      <view class="text-xs text-hint text-center mt-sm">已选 {{comicPhotos.length}} 张{{comicPhotos.length < 6 ? '（至少需要6张）' : ''}}</view>
    </view>
    <view class="section" wx:if="{{comicPhotos.length >= 6}}">
      <view class="btn btn-primary btn-block" bindtap="generateComic">📖 生成日记漫画</view>
    </view>
    <view class="section" wx:if="{{comicResult}}">
      <view class="section-title">漫画预览</view>
      <image class="result-img" src="{{comicResult}}" mode="widthFix" />
      <view class="btn btn-outline btn-block mt-md" bindtap="saveComic">💾 保存漫画</view>
    </view>
  </block>

  <!-- 漫剧模式 -->
  <block wx:if="{{mode==='series'}}">
    <view class="section">
      <view class="section-title">选择多张照片生成漫剧</view>
      <view class="photo-grid">
        <view class="photo-grid-item" wx:for="{{seriesPhotos}}" wx:key="index">
          <image class="grid-img" src="{{item}}" mode="aspectFill" />
          <view class="grid-remove" catchtap="removeSeriesPhoto" data-index="{{index}}">✕</view>
        </view>
        <view class="photo-grid-item photo-add" bindtap="chooseSeriesPhoto" wx:if="{{seriesPhotos.length < 12}}">
          <text class="text-4xl">+</text>
        </view>
      </view>
      <view class="text-xs text-hint text-center mt-sm">已选 {{seriesPhotos.length}} 张</view>
    </view>
    <view class="section" wx:if="{{seriesPhotos.length >= 3}}">
      <view class="section-title">漫剧标题</view>
      <view class="input-area">
        <input class="watermark-input" placeholder="给漫剧取个名字..." maxlength="{{30}}" value="{{seriesTitle}}" bindinput="onSeriesTitleInput" />
      </view>
      <view class="btn btn-primary btn-block mt-md" bindtap="generateSeries">🎬 生成漫剧</view>
    </view>
    <view class="section" wx:if="{{seriesResult}}">
      <view class="section-title">漫剧预览</view>
      <image class="result-img" src="{{seriesResult}}" mode="widthFix" />
      <view class="btn btn-outline btn-block mt-md" bindtap="saveSeries">💾 保存漫剧</view>
    </view>
  </block>
</view>

<!-- 隐藏 Canvas 用于水印生成 -->
<canvas canvas-id="watermarkCanvas" style="position:fixed;left:-9999px;top:-9999px;width:750px;height:750px;"></canvas>


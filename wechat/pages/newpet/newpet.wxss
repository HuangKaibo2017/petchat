.page-container { padding-bottom: 48rpx; }
.intro-card { margin: 16rpx 32rpx 24rpx; padding: 32rpx 24rpx; text-align: center; background: linear-gradient(180deg, #FFEDD5, #FFF7ED); }
.intro-icon { font-size: 56rpx; margin-bottom: 16rpx; }
.intro-title { color: #1F2937; }
.intro-desc { line-height: 1.6; }

.form-card { margin: 0 32rpx; padding: 24rpx; }
.form-item { margin-bottom: 24rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label { color: #374151; margin-bottom: 12rpx; }
.form-input { width: 100%; padding: 16rpx 20rpx; background: #F9FAFB; border-radius: 12rpx; font-size: 28rpx; color: #1F2937; }
.radio-group { gap: 16rpx; }
.radio-item { flex:1; text-align:center; padding: 16rpx 0; border-radius: 12rpx; background: #F9FAFB; font-size: 26rpx; color: #6B7280; }
.radio-active { background: #D8EBE6; color: #2D7D6E; font-weight: 600; }

.photo-row { gap: 16rpx; padding: 0 32rpx; }
.photo-upload-box { flex:1; aspect-ratio:1; border-radius: 16rpx; overflow:hidden; background:#F9FAFB; border: 2rpx dashed #D1D5DB; }
.upload-preview { width:100%; height:100%; }
.upload-hint { width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; color:#9CA3AF; }

.report-card { margin: 0 32rpx; padding: 24rpx; }
.report-section { border-left: 4rpx solid #2D7D6E; padding-left: 16rpx; }

.section { margin-bottom: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #1F2937; margin: 0 32rpx 16rpx; }

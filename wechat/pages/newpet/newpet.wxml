<nav-bar title="新宠购买指南" showBack="{{true}}" />
<view class="page-container">
  <view class="intro-card card">
    <view class="intro-icon">🐣</view>
    <view class="intro-title text-lg font-bold">新宠购买建议指南</view>
    <view class="intro-desc text-sm text-hint mt-sm">输入品种、年龄等信息，AI解析常见病、养护难点及全周期饲养成本测算</view>
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <view class="section-title">宠物信息</view>
    <view class="form-card card">
      <view class="form-item">
        <view class="form-label text-sm font-bold">品种名称</view>
        <input class="form-input" placeholder="例如：英短蓝猫、柯基犬" value="{{breed}}" bindinput="onInput" data-field="breed" />
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">年龄 / 月龄</view>
        <input class="form-input" placeholder="例如：3个月" value="{{age}}" bindinput="onInput" data-field="age" />
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">性别</view>
        <view class="radio-group flex">
          <view class="radio-item {{gender==='male'?'radio-active':''}}" bindtap="setGender" data-gender="male">♂ 公</view>
          <view class="radio-item {{gender==='female'?'radio-active':''}}" bindtap="setGender" data-gender="female">♀ 母</view>
          <view class="radio-item {{gender==='unknown'?'radio-active':''}}" bindtap="setGender" data-gender="unknown">未知</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 照片上传（五官+脚垫） -->
  <view class="section">
    <view class="section-title">上传照片 <text class="text-xs text-hint">· 可选</text></view>
    <view class="photo-row flex">
      <view class="photo-upload-box" bindtap="uploadFace">
        <image class="upload-preview" src="{{faceImage}}" mode="aspectFill" wx:if="{{faceImage}}" />
        <view class="upload-hint" wx:else>
          <text class="text-3xl">📷</text>
          <text class="text-xs text-hint">五官照</text>
        </view>
      </view>
      <view class="photo-upload-box" bindtap="uploadPaw">
        <image class="upload-preview" src="{{pawImage}}" mode="aspectFill" wx:if="{{pawImage}}" />
        <view class="upload-hint" wx:else>
          <text class="text-3xl">🐾</text>
          <text class="text-xs text-hint">脚垫照</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 生成报告 -->
  <view class="section">
    <view class="btn btn-primary btn-block" bindtap="generateGuide" disabled="{{generating}}">
      {{generating ? 'AI分析中...' : '🔍 生成购买建议报告'}}
    </view>
  </view>

  <!-- 报告结果 -->
  <view class="section" wx:if="{{report}}">
    <view class="report-card card">
      <view class="report-section" wx:if="{{report.commonDiseases}}">
        <view class="text-md font-bold mb-sm">🩺 常见病预警</view>
        <view class="text-sm text-hint">{{report.commonDiseases}}</view>
      </view>
      <view class="report-section mt-md" wx:if="{{report.careTips}}">
        <view class="text-md font-bold mb-sm">📋 养护难点</view>
        <view class="text-sm text-hint">{{report.careTips}}</view>
      </view>
      <view class="report-section mt-md" wx:if="{{report.costEstimate}}">
        <view class="text-md font-bold mb-sm">💰 全周期饲养成本测算</view>
        <view class="text-sm text-hint">{{report.costEstimate}}</view>
      </view>
      <view class="report-section mt-md" wx:if="{{report.recommendation}}">
        <view class="text-md font-bold mb-sm">⭐ 综合建议</view>
        <view class="text-sm text-hint">{{report.recommendation}}</view>
      </view>
    </view>
  </view>
</view>
<nav-bar title="收货地址" showBack="{{true}}" />

<view class="page-container">
  <view class="addr-list">
    <view class="addr-card card" wx:for="{{addressList}}" wx:key="id"
          bindtap="selectAddress" data-item="{{item}}">
      <view class="addr-card-top">
        <text class="addr-name">{{item.name}}</text>
        <text class="addr-phone">{{item.phone}}</text>
        <view class="addr-default-tag" wx:if="{{item.isDefault}}">默认</view>
      </view>
      <view class="addr-detail">{{item.region}} {{item.detail}}</view>
      <view class="addr-card-actions">
        <view class="addr-action-btn" catchtap="editAddress" data-item="{{item}}">编辑</view>
        <view class="addr-action-btn" catchtap="deleteAddress" data-id="{{item.id}}">删除</view>
        <view class="addr-action-btn" catchtap="toggleDefault" data-id="{{item.id}}" data-default="{{item.isDefault}}">
          {{item.isDefault ? '取消默认' : '设为默认'}}
        </view>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{addressList.length === 0}}" title="暂无收货地址" desc="添加一个收货地址吧" />

  <view class="addr-add-btn">
    <button class="btn btn-primary btn-block" bindtap="addAddress">新增地址</button>
  </view>
</view>

<view class="addr-modal" wx:if="{{showModal}}" catchtap="closeModal">
  <view class="addr-modal-content" catchtap="noop">
    <view class="addr-modal-title">收货地址</view>

    <view class="input-group">
      <view class="input-label">收货人</view>
      <input class="input-field" placeholder="请输入姓名" value="{{form.name}}" bindinput="onFormInput" data-field="name" />
    </view>

    <view class="input-group">
      <view class="input-label">手机号</view>
      <input class="input-field" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onFormInput" data-field="phone" />
    </view>

    <view class="input-group">
      <view class="input-label">所在地区</view>
      <picker mode="region" value="{{form.regionArr}}" bindchange="onRegionChange">
        <view class="input-field">{{form.region || '请选择省/市/区'}}</view>
      </picker>
    </view>

    <view class="input-group">
      <view class="input-label">详细地址</view>
      <input class="input-field" placeholder="街道、门牌号等" value="{{form.detail}}" bindinput="onFormInput" data-field="detail" />
    </view>

    <view class="addr-modal-bottom">
      <button class="btn btn-primary btn-block" bindtap="saveAddress">保存</button>
    </view>
  </view>
</view>

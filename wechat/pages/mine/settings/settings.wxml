<nav-bar title="设置" showBack="{{true}}" />
<view class="page-container">
  <view class="func-list">
    <view class="func-item" bindtap="toggleVoice"><view class="func-left"><text class="func-icon">🎙️</text><text class="text-md">语音输入</text></view><switch checked="{{voiceEnabled}}" bindchange="toggleVoice" color="#F97316" /></view>
    <view class="func-item" bindtap="toggleNfc"><view class="func-left"><text class="func-icon">📳</text><text class="text-md">NFC扫码弹窗</text></view><switch checked="{{nfcEnabled}}" bindchange="toggleNfc" color="#F97316" /></view>
    <view class="func-item" bindtap="clearCache"><view class="func-left"><text class="func-icon">🗑️</text><text class="text-md">清除缓存</text></view><text class="text-hint">{{cacheSize}}</text></view>
  </view>
  <view class="func-list mt-md">
    <view class="func-item" bindtap="openDoc" data-type="privacy"><view class="func-left"><text class="text-md">隐私政策</text></view><text class="text-hint">›</text></view>
    <view class="func-item" bindtap="openDoc" data-type="agreement"><view class="func-left"><text class="text-md">用户协议</text></view><text class="text-hint">›</text></view>
    <view class="func-item" bindtap="openDoc" data-type="disclaimer"><view class="func-left"><text class="text-md">免责声明</text></view><text class="text-hint">›</text></view>
  </view>
  <view class="func-list mt-md">
    <view class="func-item" bindtap="logout"><view class="func-left"><text class="text-md" style="color:#EF4444">退出登录</text></view></view>
  </view>
</view>

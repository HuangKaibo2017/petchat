.filter-tabs { padding: 16rpx 32rpx; gap: 16rpx; overflow-x: auto; white-space: nowrap; }
.filter-tab {
  display: inline-flex;
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: #6B7280;
  white-space: nowrap;
}
.filter-tab.active { background: #D8EBE6; color: #2D7D6E; font-weight: 600; }

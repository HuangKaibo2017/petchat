<nav-bar title="注册档案" showBack="{{true}}" />
<view class="page-container">
  <view class="section">
    <view class="section-title">主人信息</view>
    <view class="input-group">
      <view class="input-label">姓名 <text class="text-danger">*</text></view>
      <input class="input-field" placeholder="请输入姓名" value="{{ownerName}}" bindinput="onFieldInput" data-field="ownerName" />
    </view>
    <view class="input-group">
      <view class="input-label">手机号 <text class="text-danger">*</text></view>
      <input class="input-field" type="number" placeholder="请输入手机号" value="{{phone}}" bindinput="onFieldInput" data-field="phone" maxlength="11" />
    </view>
    <view class="input-group">
      <view class="input-label">出生年月日</view>
      <picker mode="date" value="{{birthday}}" bindchange="onBirthdayChange">
        <view class="input-field">{{birthday || '请选择出生日期（可选）'}}</view>
      </picker>
    </view>
  </view>

  <view class="section">
    <view class="section-title">宠物信息</view>
    <view class="section-subtitle">请至少添加一只宠物</view>

    <view wx:for="{{pets}}" wx:key="index" class="pet-form-card card">
      <view class="flex-between mb-sm">
        <view class="text-md font-bold">宠物 {{index + 1}}</view>
        <view class="text-xs text-danger" bindtap="removePet" data-index="{{index}}" wx:if="{{pets.length > 1}}">删除</view>
      </view>
      <view class="input-group">
        <view class="input-label">名字 <text class="text-danger">*</text></view>
        <input class="input-field" placeholder="给宠物取个名字" value="{{item.name}}" bindinput="onPetFieldInput" data-index="{{index}}" data-field="name" />
      </view>
      <view class="input-group">
        <view class="input-label">品种 <text class="text-danger">*</text></view>
        <picker range="{{breedList}}" value="{{item.breedIndex}}" bindchange="onBreedChange" data-index="{{index}}">
          <view class="input-field">{{item.breed || '请选择品种'}}</view>
        </picker>
      </view>
      <view class="input-group">
        <view class="input-label">年龄</view>
        <input class="input-field" placeholder="如：2岁" value="{{item.age}}" bindinput="onPetFieldInput" data-index="{{index}}" data-field="age" />
      </view>
      <view class="flex-between" style="gap:16rpx">
        <view class="input-group flex-1">
          <view class="input-label">性别</view>
          <view class="gender-row">
            <view class="gender-btn {{item.gender === 'male' ? 'active' : ''}}" bindtap="selectGender" data-index="{{index}}" data-gender="male">♂ 公</view>
            <view class="gender-btn {{item.gender === 'female' ? 'active' : ''}}" bindtap="selectGender" data-index="{{index}}" data-gender="female">♀ 母</view>
          </view>
        </view>
        <view class="input-group flex-1">
          <view class="input-label">绝育</view>
          <view class="gender-row">
            <view class="gender-btn {{item.neutered === true ? 'active' : ''}}" bindtap="selectNeutered" data-index="{{index}}" data-value="{{true}}">已绝育</view>
            <view class="gender-btn {{item.neutered === false ? 'active' : ''}}" bindtap="selectNeutered" data-index="{{index}}" data-value="{{false}}">未绝育</view>
          </view>
        </view>
      </view>
      <view class="input-group">
        <view class="input-label">病史（可选）</view>
        <input class="input-field" placeholder="如：曾患猫癣、肠胃炎" value="{{item.history}}" bindinput="onPetFieldInput" data-index="{{index}}" data-field="history" />
      </view>
      <view class="input-group">
        <view class="input-label">防疫情况（可选）</view>
        <input class="input-field" placeholder="如：已打三联、狂犬疫苗" value="{{item.vaccine}}" bindinput="onPetFieldInput" data-index="{{index}}" data-field="vaccine" />
      </view>
      <view class="input-group">
        <view class="input-label">照片</view>
        <view class="flex items-center">
          <image class="avatar-md" src="{{item.avatar || '/images/default-pet.png'}}" mode="aspectFill" bindtap="choosePetAvatar" data-index="{{index}}" />
          <text class="text-xs text-hint ml-sm">点击更换照片</text>
        </view>
      </view>
    </view>

    <view class="add-pet-btn text-center mt-md" bindtap="addPet" wx:if="{{pets.length < 5}}">
      <text class="text-primary">+ 添加更多宠物</text>
    </view>
  </view>

  <view class="section">
    <button class="btn btn-primary btn-block" bindtap="submitRegister">完成注册</button>
  </view>

  <view style="height: 120rpx"></view>
</view>

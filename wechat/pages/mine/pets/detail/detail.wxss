.page-container {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.pet-header {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 40rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
  margin-bottom: 24rpx;
}

.pet-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #F0F0F0;
}

.pet-header-info {
  flex: 1;
  min-width: 0;
}

.pet-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.pet-subtitle {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.pet-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.detail-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.info-grid {
  display: flex;
  flex-wrap: wrap;
}

.info-item {
  width: 50%;
  margin-bottom: 24rpx;
}

.info-item-full {
  width: 100%;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  word-break: break-all;
}

.action-bar {
  margin-top: 48rpx;
}

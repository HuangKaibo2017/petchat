.page-container { min-height: 100vh; background: #FAF9F5; padding-bottom: 40rpx; }
.device-icon { font-size: 40rpx; }
.quota-grid { display: grid; gap: 16rpx; }
.quota-grid:first-of-type { grid-template-columns: repeat(3, 1fr); }
.quota-item { text-align: center; padding: 24rpx 16rpx; }
.quota-num { margin-bottom: 4rpx; }

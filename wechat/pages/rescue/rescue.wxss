/* ═══════════════════════════════════════════
   Rescue Page — 救助专区
   ═══════════════════════════════════════════ */
.page-container { padding-bottom: 48rpx; }

.tab-bar {
  display: flex;
  margin: 16rpx 32rpx 24rpx;
  background: #F3F4F6;
  border-radius: 16rpx;
  padding: 6rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #6B7280;
  transition: all 0.2s;
}
.tab-active {
  background: #FFFFFF;
  color: #2D7D6E;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.org-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
}
.org-card {
  display: inline-block;
  width: 200rpx;
  margin-right: 16rpx;
  padding: 24rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  text-align: center;
  white-space: normal;
  vertical-align: top;
}
.org-avatar {
  font-size: 44rpx;
  margin-bottom: 12rpx;
}
.org-name { color: #1F2937; margin-bottom: 8rpx; }
.org-phone { color: #2D7D6E; margin-bottom: 8rpx; }
.org-desc { display: block; }

.section-header {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.help-card, .adopt-card {
  margin: 0 32rpx 16rpx;
  padding: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #9CA3AF;
}

.donate-banner {
  margin: 0 32rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FEF3C7, #FFEDD5);
}
.donate-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: rgba(249,115,22,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.volunteer-card {
  margin: 0 32rpx;
  padding: 24rpx;
}
.volunteer-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #D8EBE6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.section { margin-bottom: 32rpx; }
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin: 0 32rpx 16rpx;
}

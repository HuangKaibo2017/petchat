.page { min-height: 100vh; background: linear-gradient(180deg, #e8faf0 0%, #fff 30%); padding-bottom: 40rpx; }

.loading-wrap, .empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 4rpx solid #e0e0e0; border-top-color: #2ecc71; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.report-body { padding: 0 32rpx; }

.header { display: flex; align-items: center; padding: 40rpx 0 24rpx; }
.header-info { flex: 1; }
.pet-name { font-size: 36rpx; font-weight: 700; color: #1a1a2e; display: block; }
.report-label { font-size: 24rpx; color: #2ecc71; margin-top: 4rpx; }

.card { background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); }
.core-card.health-card { background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%); }
.core-card .card-title { color: rgba(255,255,255,0.8); }
.core-text { font-size: 30rpx; line-height: 1.7; color: #fff; display: block; margin-top: 12rpx; }
.highlight-card { background: linear-gradient(135deg, #ffe8e8 0%, #ffd4d4 100%); border: 2rpx solid #e74c3c; }

.card-title { font-size: 28rpx; font-weight: 600; color: #1a1a2e; margin-bottom: 16rpx; }

.score-wrap { display: flex; align-items: baseline; justify-content: center; margin: 20rpx 0; }
.score-num { font-size: 72rpx; font-weight: 700; color: #fff; }
.score-unit { font-size: 28rpx; color: rgba(255,255,255,0.7); margin-left: 8rpx; }
.score-bar { height: 8rpx; background: rgba(255,255,255,0.3); border-radius: 4rpx; margin: 12rpx 0 8rpx; overflow: hidden; }
.score-fill { height: 100%; background: #fff; border-radius: 4rpx; transition: width 0.6s ease; }

.section-text { font-size: 28rpx; line-height: 1.7; color: #333; display: block; margin-top: 16rpx; }

.care-list { margin-top: 12rpx; }
.care-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.care-item:last-child { border-bottom: none; }
.care-title { font-size: 28rpx; font-weight: 500; color: #333; display: block; }
.care-desc { margin-top: 6rpx; display: block; }

.actions { display: flex; gap: 20rpx; margin: 40rpx 0 20rpx; }
.action-btn { flex: 1; height: 88rpx; border-radius: 44rpx; font-size: 28rpx; font-weight: 500; display: flex; align-items: center; justify-content: center; background: #2ecc71; color: #fff; border: none; }
.action-btn.secondary { background: #e8faf0; color: #2ecc71; }
.action-btn::after { border: none; }

.footer { text-align: center; padding: 40rpx 0; }
.footer text { display: block; margin-top: 8rpx; }

.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 32rpx; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-hint { color: #999; }

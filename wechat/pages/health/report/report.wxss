.report-header {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #FFF7ED, #FFFFFF);
}
.report-pet-name { color: #F97316; }

.risk-banner {
  margin: 16rpx 32rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.risk-icon { font-size: 64rpx; }

.report-section { margin: 16rpx 32rpx; }
.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #F97316;
  margin-bottom: 16rpx;
}

.symptom-detail { line-height: 1.8; }
.symptom-mapping { background: #FEF2F2; padding: 16rpx; border-radius: 12rpx; }

.deficiency-detail {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.deficiency-detail:last-child { border-bottom: none; }

.emergency-card {
  border: 2rpx solid #FECACA;
  background: #FFF5F5;
}

.care-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.care-item:last-child { border-bottom: none; }

.disclaimer { margin: 24rpx 32rpx; padding: 16rpx; border-radius: 16rpx; }

.report-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
  padding-bottom: env(safe-area-inset-bottom);
}
.action-btn { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }

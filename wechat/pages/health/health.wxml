<nav-bar title="宠物体质分析" showBack="{{true}}" />
<view class="page-container">
  <!-- Step 0: 选择分析模式 -->
  <view class="section" wx:if="{{step === 0}}">
    <view class="section-title">选择分析模式</view>
    <view class="section-subtitle">¥9.9 / 次 · 每次扣费后生成报告</view>

    <view class="mode-cards">
      <view class="mode-card card" bindtap="selectMode" data-mode="overall">
        <view class="mode-icon">🔬</view>
        <view class="mode-title text-lg font-bold">整体分析</view>
        <view class="mode-desc text-sm text-hint">依据当下时间自动出综合评分与雷达图，不需输入数字</view>
        <view class="mode-tag tag tag-primary mt-sm">五运六气</view>
      </view>

      <view class="mode-card card" bindtap="selectMode" data-mode="specific">
        <view class="mode-icon">📋</view>
        <view class="mode-title text-lg font-bold">具体分析</view>
        <view class="mode-desc text-sm text-hint">输入症状与数字，出具单项报告，支持分屏/整页保存转发</view>
        <view class="mode-tag tag tag-success mt-sm">含平台二维码</view>
      </view>
    </view>
  </view>

  <!-- Step 1: 选择宠物 -->
  <view class="section" wx:if="{{step === 1}}">
    <view class="section-title">选择宠物</view>
    <pet-card wx:for="{{pets}}" wx:key="id" pet="{{item}}" selected="{{selectedPet && selectedPet.id === item.id}}" showArrow="{{false}}" bind:select="onSelectPet" />
    <button class="btn btn-primary btn-block mt-lg" disabled="{{!selectedPet}}" bindtap="nextStep">下一步</button>
  </view>

  <!-- Step 2: 整体分析（自动） -->
  <view class="section" wx:if="{{step === 2 && mode === 'overall'}}">
    <view class="section-title">整体分析</view>
    <view class="section-subtitle">基于五运六气，自动生成综合评分与雷达图</view>

    <view class="overall-info card">
      <view class="flex items-center mb-md">
        <image class="avatar-md" src="{{selectedPet.avatar || '/images/default-pet.png'}}" mode="aspectFill" />
        <view class="ml-md">
          <view class="text-lg font-bold">{{selectedPet.name}}</view>
          <view class="text-xs text-hint">{{selectedPet.breed}} · {{selectedPet.age}}</view>
        </view>
      </view>
      <view class="info-row text-sm">
        <text class="text-hint">分析时间：</text>
        <text>{{currentTime}}</text>
      </view>
      <view class="info-row text-sm">
        <text class="text-hint">五运六气：</text>
        <text>{{wuyunInfo}}</text>
      </view>
    </view>

    <button class="btn btn-primary btn-block mt-lg" bindtap="generateOverall">生成体质报告</button>
  </view>

  <!-- Step 2: 具体分析（输入症状） -->
  <view class="section" wx:if="{{step === 2 && mode === 'specific'}}">
    <view class="section-title">症状描述</view>
    <view class="section-subtitle">请详细描述宠物的异常表现</view>

    <textarea class="input-field input-textarea" placeholder="例如：猫咪这两天频繁上厕所，尿量少，精神不太好…" value="{{symptom}}" bindinput="onSymptomInput" maxlength="500" />

    <view class="upload-row flex mt-sm">
      <view class="upload-btn" bindtap="chooseImage"><text>📷 上传照片</text></view>
    </view>
    <image class="upload-preview" wx:if="{{symptomImage}}" src="{{symptomImage}}" mode="aspectFill" />

    <view class="section-title mt-lg">症状持续时长</view>
    <view class="duration-grid">
      <view class="duration-item {{duration === '1-3天' ? 'active' : ''}}" bindtap="selectDuration" data-dur="1-3天">1-3天</view>
      <view class="duration-item {{duration === '4-7天' ? 'active' : ''}}" bindtap="selectDuration" data-dur="4-7天">4-7天</view>
      <view class="duration-item {{duration === '1-2周' ? 'active' : ''}}" bindtap="selectDuration" data-dur="1-2周">1-2周</view>
      <view class="duration-item {{duration === '2周以上' ? 'active' : ''}}" bindtap="selectDuration" data-dur="2周以上">2周以上</view>
    </view>

    <view class="section-title mt-lg">异常表现</view>
    <textarea class="input-field input-textarea" placeholder="补充其他异常表现…" value="{{abnormal}}" bindinput="onAbnormalInput" maxlength="300" />

    <view class="card bg-primary-light mt-lg">
      <view class="text-sm text-muted text-center">
        <text class="font-bold">数字卦</text>
        <text> · 请输入6个数字（0-9）辅助分析</text>
      </view>
    </view>

    <view class="number-grid mt-sm">
      <input wx:for="{{numbers}}" wx:key="index" class="number-input {{item ? 'filled' : ''}}" type="number" maxlength="1" value="{{item}}" bindinput="onNumberInput" data-index="{{index}}" />
    </view>

    <button class="btn btn-primary btn-block mt-xl" disabled="{{!canSubmit}}" bindtap="generateSpecific">生成体质报告</button>
  </view>

  <loading visible="{{generating}}" text="Gengdongta正在分析中…" />
</view>

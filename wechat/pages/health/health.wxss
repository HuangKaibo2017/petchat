/* ═══════════════════════════════════════════
   Health Page — 宠物体质分析
   ═══════════════════════════════════════════ */

/* ─── 模式选择卡片 ─── */
.mode-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 32rpx;
}
.mode-card {
  padding: 32rpx;
  transition: all 0.2s;
}
.mode-card:active { transform: scale(0.98); }
.mode-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.mode-title { margin-bottom: 8rpx; }
.mode-desc { display: block; line-height: 1.5; }
.mode-tag { margin-left: 0; }

/* ─── 整体分析信息 ─── */
.overall-info { padding: 32rpx; }
.info-row {
  padding: 8rpx 0;
  display: flex;
  align-items: center;
}

/* ─── 上传 ─── */
.upload-row { gap: 16rpx; }
.upload-btn {
  padding: 16rpx 24rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #6B7280;
}
.upload-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-top: 16rpx;
}

/* ─── 时长选择 ─── */
.duration-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
  padding: 0 32rpx;
}
.duration-item {
  padding: 16rpx 0;
  text-align: center;
  border-radius: 12rpx;
  background: #F3F4F6;
  font-size: 24rpx;
  color: #6B7280;
  transition: all 0.2s;
}
.duration-item.active {
  background: #2D7D6E;
  color: #FFFFFF;
  font-weight: 600;
}

/* ─── 数字输入 ─── */
.number-grid {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  padding: 0 32rpx;
}
.number-input {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  background: #F3F4F6;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}
.number-input.filled {
  border-color: #2D7D6E;
  background: #F0FDF4;
}

/* ─── 步骤进度 ─── */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx 32rpx;
}
.step-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #E5E7EB;
  transition: all 0.3s;
}
.step-dot.active { background: #2D7D6E; transform: scale(1.3); }
.step-line {
  width: 40rpx;
  height: 2rpx;
  background: #E5E7EB;
}
.step-line.active { background: #2D7D6E; }

<nav-bar title="{{pageTitle}}" showBack="{{true}}" />
<view class="page-container">
  <!-- Step 1: Select Pet -->
  <view class="section" wx:if="{{step === 0}}">
    <view class="section-title">选择宠物</view>
    <view class="section-subtitle">请选择需要解读的宠物</view>
    <pet-card
      wx:for="{{pets}}"
      wx:key="id"
      pet="{{item}}"
      selected="{{selectedPet && selectedPet.id === item.id}}"
      showArrow="{{false}}"
      bind:select="onSelectPet"
    />
    <view class="add-pet-hint text-center" wx:if="{{!pets.length}}" bindtap="goRegister">
      <text class="text-hint">暂未添加宠物，点击添加 ›</text>
    </view>
    <button class="btn btn-primary btn-block mt-lg" disabled="{{!selectedPet}}" bindtap="nextStep">
      下一步
    </button>
  </view>

  <!-- Step 2: Input Question & Divination Setup -->
  <view class="section" wx:if="{{step === 1}}">
    <view class="section-title">宠物状态问题</view>
    <view class="section-subtitle">描述您想了解的宠物状态</view>

    <!-- Question Input with Hint Bulb -->
    <view class="question-area">
      <textarea
        class="input-field input-textarea"
        placeholder="例如：我家猫咪这两天不爱动，总是躲在角落里…"
        value="{{question}}"
        bindinput="onQuestionInput"
        maxlength="500"
      />
      <view class="question-hint-bulb" bindtap="toggleQuestionHints">
        <text class="bulb-icon">💡</text>
        <text class="bulb-text text-xs text-hint">问题引导</text>
      </view>
    </view>

    <!-- Question Hints Panel -->
    <view class="hints-panel" wx:if="{{showQuestionHints}}">
      <view class="hint-item" wx:for="{{questionHints}}" wx:key="*this" bindtap="selectHint" data-hint="{{item}}">
        {{item}}
      </view>
    </view>

    <!-- Image / Voice Upload -->
    <view class="upload-row flex mt-md">
      <view class="upload-btn" bindtap="chooseImage">
        <text>📷 图片</text>
      </view>
      <view class="upload-btn" bindtap="startRecord">
        <text>🎤 语音</text>
      </view>
    </view>
    <image class="upload-preview" wx:if="{{uploadImage}}" src="{{uploadImage}}" mode="aspectFill" />

    <!-- Divination System Selection -->
    <view class="section-title mt-lg">起卦体系</view>
    <view class="divination-grid">
      <view class="divination-item {{divSystem === 'liuyao' ? 'active' : ''}}" bindtap="selectDivSystem" data-system="liuyao">
        <view class="div-system-icon">☯</view>
        <view class="div-name text-sm">六爻</view>
        <view class="div-desc text-xs text-hint">输入6个数字</view>
      </view>
      <view class="divination-item {{divSystem === 'meihua' ? 'active' : ''}}" bindtap="selectDivSystem" data-system="meihua">
        <view class="div-system-icon">🌸</view>
        <view class="div-name text-sm">梅花易数</view>
        <view class="div-desc text-xs text-hint">输入3个数字</view>
      </view>
      <view class="divination-item {{divSystem === 'daliuren' ? 'active' : ''}}" bindtap="selectDivSystem" data-system="daliuren">
        <view class="div-system-icon">🌊</view>
        <view class="div-name text-sm">大六壬</view>
        <view class="div-desc text-xs text-hint">输入3个数字</view>
      </view>
      <view class="divination-item {{divSystem === 'tarot' ? 'active' : ''}}" bindtap="selectDivSystem" data-system="tarot">
        <view class="div-system-icon">🃏</view>
        <view class="div-name text-sm">塔罗</view>
        <view class="div-desc text-xs text-hint">无需输入数字</view>
      </view>
    </view>

    <!-- Number Input (non-tarot) -->
    <view class="number-input-section mt-md" wx:if="{{divSystem !== 'tarot'}}">
      <view class="section-subtitle" wx:if="{{divSystem === 'liuyao'}}">请输入6个数字（0-9）</view>
      <view class="section-subtitle" wx:else>请输入3个数字（0-9）</view>
      <view class="number-grid">
        <input
          wx:for="{{numberInputs}}"
          wx:key="index"
          class="number-input {{item ? 'filled' : ''}}"
          type="number"
          maxlength="1"
          value="{{item}}"
          bindinput="onNumberInput"
          data-index="{{index}}"
        />
      </view>
      <view class="text-xs text-hint mt-sm">起卦时间：后台自动获取当前时间</view>
    </view>

    <view class="text-xs text-hint text-center mt-md" wx:if="{{divSystem === 'tarot'}}">
      塔罗模式下，提交后将自动跳转至选牌页面
    </view>

    <button
      class="btn btn-primary btn-block mt-xl"
      disabled="{{!canSubmit}}"
      bindtap="submitEmotion"
    >
      {{divSystem === 'tarot' ? '开始选牌' : '生成报告'}}
    </button>
  </view>

  <!-- Tarot Card Selection (Step 3) -->
  <view class="section" wx:if="{{step === 2 && divSystem === 'tarot'}}">
    <view class="section-title">选择塔罗牌</view>
    <view class="section-subtitle">请凭直觉选择3张牌</view>
    <view class="tarot-grid">
      <view
        class="tarot-card {{selectedCards.indexOf(index) > -1 ? 'revealed' : 'hidden'}}"
        wx:for="{{tarotCards}}"
        wx:key="*this"
        bindtap="selectTarotCard"
        data-index="{{index}}"
      >
        <view class="tarot-back" wx:if="{{selectedCards.indexOf(index) === -1}}">🃏</view>
        <view class="tarot-front" wx:else>
          <text class="tarot-emoji">{{item}}</text>
          <text class="text-xs text-hint">第{{selectedCards.indexOf(index) + 1}}张</text>
        </view>
      </view>
    </view>
    <button
      class="btn btn-primary btn-block mt-lg"
      disabled="{{selectedCards.length < 3}}"
      bindtap="generateReport"
    >
      确认选牌，生成报告
    </button>
  </view>

  <!-- Loading State -->
  <loading visible="{{generating}}" text="Gengdongta正在解读中…" />
</view>

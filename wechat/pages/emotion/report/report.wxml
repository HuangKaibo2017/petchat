<nav-bar title="解读报告" showBack="{{true}}" />
<view class="page-container">
  <!-- Report Header -->
  <view class="report-header">
    <view class="report-pet-info">
      <image class="avatar-lg" src="{{report.petAvatar || '/images/default-pet.png'}}" mode="aspectFill" />
      <view class="report-pet-name text-xl font-bold mt-sm">{{report.petName}}</view>
      <view class="report-time text-xs text-hint">{{report.time}}</view>
    </view>
    <view class="divination-badge">
      <text>{{divSystemLabel}}</text>
    </view>
  </view>

  <!-- Core Answer -->
  <view class="report-section card">
    <view class="section-label">💬 核心回答</view>
    <view class="core-answer text-lg font-bold">{{report.coreAnswer}}</view>
    <view class="core-basis text-sm text-muted mt-sm">{{report.coreBasis}}</view>
  </view>

  <!-- Today's Overall Status -->
  <view class="report-section card">
    <view class="section-label">📊 今日整体状态</view>
    <view class="status-row">
      <view class="status-item">
        <view class="status-value text-lg font-bold">{{report.foodSatisfaction}}</view>
        <view class="status-label text-xs text-hint">饮食满意度</view>
      </view>
      <view class="status-item">
        <view class="status-value text-lg font-bold">{{report.moodLevel}}</view>
        <view class="status-label text-xs text-hint">情绪开心度</view>
      </view>
      <view class="status-item">
        <view class="status-value text-lg font-bold">{{report.bodyStatus}}</view>
        <view class="status-label text-xs text-hint">身体状态</view>
      </view>
    </view>
    <view class="status-summary text-md mt-md">{{report.statusSummary}}</view>
  </view>

  <!-- Pet's View of Owner -->
  <view class="report-section card highlight-card">
    <view class="section-label">👀 它眼中的你</view>
    <view class="owner-view text-md italic">{{report.ownerView}}</view>
  </view>

  <!-- Pet's Message -->
  <view class="report-section card love-card">
    <view class="section-label">❤️ 它想对你说</view>
    <view class="pet-message text-md">{{report.petMessage}}</view>
    <view class="pet-wish text-sm text-muted mt-sm" wx:if="{{report.petWish}}">{{report.petWish}}</view>
  </view>

  <!-- Care Plan -->
  <view class="report-section card">
    <view class="section-label">🌿 调理方案</view>
    <view class="care-item" wx:for="{{report.carePlan}}" wx:key="title">
      <view class="care-title text-md font-bold">{{item.title}}</view>
      <view class="care-desc text-sm text-muted">{{item.desc}}</view>
    </view>
  </view>

  <!-- Recommended Products -->
  <view class="report-section card" wx:if="{{report.products && report.products.length}}">
    <view class="section-label">🛒 推荐商品</view>
    <view class="product-row">
      <view class="product-item" wx:for="{{report.products}}" wx:key="id" bindtap="goProduct" data-id="{{item.id}}">
        <image class="product-img" src="{{item.image}}" mode="aspectFill" />
        <view class="product-name text-sm">{{item.name}}</view>
        <view class="product-price text-primary font-bold">¥{{item.price}}</view>
      </view>
    </view>
  </view>

  <!-- Risk Disclaimer -->
  <view class="disclaimer card bg-primary-light">
    <view class="text-xs text-hint text-center">
      ⚠️ 内容由AI生成，不可作为决策依据
    </view>
  </view>

  <!-- Actions -->
  <view class="report-actions flex-between px-md py-md">
    <view class="action-btn" bindtap="toggleFavorite">
      <text class="text-lg">{{favorited ? '❤️' : '🤍'}}</text>
      <text class="text-xs text-hint">收藏</text>
    </view>
    <view class="action-btn" bindtap="downloadReport">
      <text class="text-lg">📥</text>
      <text class="text-xs text-hint">保存</text>
    </view>
    <view class="action-btn" bindtap="shareReport">
      <text class="text-lg">📤</text>
      <text class="text-xs text-hint">分享</text>
    </view>
    <view class="action-btn" bindtap="goShop">
      <text class="text-lg">🛒</text>
      <text class="text-xs text-hint">商城</text>
    </view>
  </view>

  <view style="height: 120rpx"></view>
</view>

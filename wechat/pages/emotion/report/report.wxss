.page { min-height: 100vh; background: linear-gradient(180deg, #f0f4ff 0%, #fff 30%); padding-bottom: 40rpx; }

.loading-wrap, .empty-wrap { display: flex; flex-direction: column; align-items: center; justify-content: center; padding-top: 200rpx; }
.loading-spinner { width: 60rpx; height: 60rpx; border: 4rpx solid #e0e0e0; border-top-color: #6b5ce7; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.report-body { padding: 0 32rpx; }

.header { display: flex; align-items: center; padding: 40rpx 0 24rpx; }
.pet-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 20rpx; }
.header-info { flex: 1; }
.pet-name { font-size: 36rpx; font-weight: 700; color: #1a1a2e; display: block; }
.report-label { font-size: 24rpx; color: #6b5ce7; margin-top: 4rpx; }
.div-system { font-size: 22rpx; color: #999; background: #f5f5f5; padding: 4rpx 16rpx; border-radius: 20rpx; }

.card { background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04); }
.core-card { background: linear-gradient(135deg, #6b5ce7 0%, #8b7cf0 100%); }
.core-card .card-title { color: rgba(255,255,255,0.8); }
.core-text { font-size: 30rpx; line-height: 1.7; color: #fff; display: block; margin-top: 12rpx; }
.basis-text { color: rgba(255,255,255,0.7) !important; margin-top: 16rpx; display: block; }
.highlight-card { background: linear-gradient(135deg, #fff8e1 0%, #fff3cd 100%); border: 2rpx solid #ffc107; }

.card-title { font-size: 28rpx; font-weight: 600; color: #1a1a2e; margin-bottom: 16rpx; }

.stat-row { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.stat-row:last-child { border-bottom: none; }
.stat-label { font-size: 28rpx; color: #666; }
.stat-value { font-size: 28rpx; font-weight: 600; color: #6b5ce7; }

.section-text { font-size: 28rpx; line-height: 1.7; color: #333; display: block; margin-top: 16rpx; }

.product-list { margin-top: 12rpx; }
.product-item { padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.product-item:last-child { border-bottom: none; }
.product-name { font-size: 28rpx; font-weight: 500; color: #333; display: block; }
.product-desc { margin-top: 6rpx; display: block; }

.actions { display: flex; gap: 20rpx; margin: 40rpx 0 20rpx; }
.action-btn { flex: 1; height: 88rpx; border-radius: 44rpx; font-size: 28rpx; font-weight: 500; display: flex; align-items: center; justify-content: center; background: #6b5ce7; color: #fff; border: none; }
.action-btn.secondary { background: #f0eeff; color: #6b5ce7; }
.action-btn::after { border: none; }

.footer { text-align: center; padding: 40rpx 0; }
.footer text { display: block; margin-top: 8rpx; }

.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 32rpx; }
.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-hint { color: #999; }

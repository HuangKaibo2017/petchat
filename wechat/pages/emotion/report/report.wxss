.report-header {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #D8EBE6, #FFFFFF);
  position: relative;
}
.report-pet-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.report-pet-name {
  color: #2D7D6E;
}
.divination-badge {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  padding: 8rpx 20rpx;
  background: #F3F4F6;
  border-radius: 9999rpx;
  font-size: 24rpx;
  color: #6B7280;
}

.report-section {
  margin: 16rpx 32rpx;
}
.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D7D6E;
  margin-bottom: 16rpx;
}

.core-answer {
  color: #1F2937;
  line-height: 1.6;
}
.core-basis {
  padding-left: 16rpx;
  border-left: 4rpx solid #2D7D6E;
}

.status-row {
  display: flex;
  justify-content: space-around;
}
.status-item {
  text-align: center;
}
.status-value {
  color: #2D7D6E;
}
.status-summary {
  background: #D8EBE6;
  padding: 16rpx;
  border-radius: 12rpx;
  line-height: 1.6;
}

.highlight-card {
  background: linear-gradient(135deg, #E8F5F0, #D8EBE6);
  border: 2rpx solid #FDE68A;
}
.owner-view {
  line-height: 1.8;
  color: #92400E;
}

.love-card {
  background: linear-gradient(135deg, #FCE7F3, #FFF1F2);
  border: 2rpx solid #FBCFE8;
}
.pet-message {
  color: #9D174D;
  line-height: 1.8;
  font-size: 30rpx;
}

.care-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.care-item:last-child { border-bottom: none; }
.care-title { margin-bottom: 4rpx; }

.product-row {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
}
.product-item {
  min-width: 200rpx;
  background: #F9FAFB;
  border-radius: 16rpx;
  overflow: hidden;
}
.product-img {
  width: 200rpx;
  height: 160rpx;
}
.product-name {
  padding: 8rpx 12rpx 4rpx;
}
.product-price {
  padding: 0 12rpx 12rpx;
}

.disclaimer {
  margin: 24rpx 32rpx;
  padding: 16rpx;
  border-radius: 16rpx;
}

.report-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
  padding-bottom: env(safe-area-inset-bottom);
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

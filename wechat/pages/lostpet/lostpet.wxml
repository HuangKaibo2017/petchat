<nav-bar title="丢失方向建议" showBack="{{true}}" />
<view class="page-container">
  <view class="intro-card card">
    <view class="intro-icon">🧭</view>
    <view class="intro-title text-lg font-bold">宠物丢失方向建议</view>
    <view class="intro-desc text-sm text-hint mt-sm">填报走失特征与环境因素，AI预判宠物当前状态与可能藏身路线，自动生成寻宠求助文案模板</view>
  </view>

  <view class="section">
    <view class="section-title">走失信息</view>
    <view class="form-card card">
      <view class="form-item">
        <view class="form-label text-sm font-bold">宠物名称</view>
        <input class="form-input" placeholder="请输入" value="{{petName}}" bindinput="onInput" data-field="petName" />
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">品种 / 特征</view>
        <input class="form-input" placeholder="例如：橘猫、白色小型犬" value="{{breed}}" bindinput="onInput" data-field="breed" />
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">走失地点</view>
        <input class="form-input" placeholder="例如：南山区科技园附近" value="{{location}}" bindinput="onInput" data-field="location" />
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">走失时间</view>
        <picker mode="date" value="{{lostDate}}" bindchange="onDateChange">
          <view class="form-input">{{lostDate || '请选择日期'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">环境因素</view>
        <view class="chip-group flex">
          <view class="chip {{envResidential?'chip-active':''}}" bindtap="toggleEnv" data-env="residential">住宅区</view>
          <view class="chip {{envPark?'chip-active':''}}" bindtap="toggleEnv" data-env="park">公园绿地</view>
          <view class="chip {{envRoad?'chip-active':''}}" bindtap="toggleEnv" data-env="road">公路旁</view>
          <view class="chip {{envWater?'chip-active':''}}" bindtap="toggleEnv" data-env="water">水域附近</view>
          <view class="chip {{envCommercial?'chip-active':''}}" bindtap="toggleEnv" data-env="commercial">商业区</view>
        </view>
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">感应数字 <text class="text-xs text-hint">· 直觉数字</text></view>
        <input class="form-input" type="number" placeholder="请输入一个1-64的数字" value="{{senseNum}}" bindinput="onInput" data-field="senseNum" maxlength="2" />
      </view>
    </view>
  </view>

  <view class="section">
    <view class="btn btn-primary btn-block" bindtap="generateReport" disabled="{{generating}}">
      {{generating ? 'AI分析中...' : '🔮 预判方向与生成寻宠文案'}}
    </view>
  </view>

  <view class="section" wx:if="{{report}}">
    <view class="report-card card">
      <view class="report-section" wx:if="{{report.predictedStatus}}">
        <view class="text-md font-bold mb-sm">🔍 当前状态预判</view>
        <view class="text-sm text-hint">{{report.predictedStatus}}</view>
      </view>
      <view class="report-section mt-md" wx:if="{{report.direction}}">
        <view class="text-md font-bold mb-sm">🧭 可能藏身方向</view>
        <view class="text-sm text-hint">{{report.direction}}</view>
      </view>
      <view class="report-section mt-md" wx:if="{{report.actionPlan}}">
        <view class="text-md font-bold mb-sm">📋 行动建议</view>
        <view class="text-sm text-hint">{{report.actionPlan}}</view>
      </view>
      <view class="report-section mt-md" wx:if="{{report.socialTemplate}}">
        <view class="text-md font-bold mb-sm">📢 寻宠文案模板</view>
        <view class="text-sm text-hint template-text">{{report.socialTemplate}}</view>
        <view class="btn btn-outline btn-sm mt-md" bindtap="copyTemplate">📋 一键复制文案</view>
      </view>
    </view>
  </view>
</view>
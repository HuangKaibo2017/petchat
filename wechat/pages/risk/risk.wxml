<nav-bar title="人宠共生报告" showBack="{{true}}" />
<view class="page-container section">

  <view class="section-title">人宠共生体质报告</view>
  <view class="section-subtitle">爱宠如照镜 — 通过爱宠的体质表现，温和映照主人的健康状态</view>

  <!-- Pet selector -->
  <view class="form-group mt-xl">
    <view class="form-label">选择宠物</view>
    <picker mode="selector" range="{{petNames}}" bindchange="onPetChange" value="{{petIndex}}">
      <view class="input-field picker-field">{{petNames[petIndex] || '请选择宠物'}}</view>
    </picker>
  </view>

  <!-- Pet info preview -->
  <view wx:if="{{selectedPet}}" class="pet-info-card card mt-md">
    <view class="info-row"><text class="info-key">品种</text><text class="info-val">{{selectedPet.breed}}</text></view>
    <view class="info-row"><text class="info-key">年龄</text><text class="info-val">{{selectedPet.age}}</text></view>
    <view class="info-row"><text class="info-key">性别</text><text class="info-val">{{selectedPet.gender === 'male' ? '公' : '母'}}{{selectedPet.neutered ? '·已绝育' : '·未绝育'}}</text></view>
    <view wx:if="{{selectedPet.tags && selectedPet.tags.length}}" class="info-row">
      <text class="info-key">体质标签</text>
      <view class="info-val"><text wx:for="{{selectedPet.tags}}" wx:key="*this" class="meta-tag">{{item}}</text></view>
    </view>
  </view>

  <!-- Core concept -->
  <view class="concept-card card mt-lg">
    <view class="concept-icon">🪞</view>
    <view class="concept-text">
      <view class="text-md font-bold">爱宠如照镜</view>
      <view class="text-xs text-hint mt-xs">宠物的体质状态是主人生活习惯的一面镜子。通过解读宠物的脾虚、肝郁、肾虚等表现，温和映射主人的作息、饮食、情绪状态。</view>
    </view>
  </view>

  <button class="btn btn-primary btn-block mt-xl" disabled="{{!selectedPet}}" bindtap="generateReport">
    🔍 生成人宠共生报告
  </button>

  <loading visible="{{generating}}" text="正在分析人宠体质关联…" />
</view>

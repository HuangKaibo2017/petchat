/* ══════════════════════════════════════
   人宠共生体质报告
   ══════════════════════════════════════ */

/* ── Header ── */
.rp-header {
  position: relative;
  padding: 56rpx 40rpx 44rpx;
  background: linear-gradient(160deg, #F0F4FF 0%, #DDE5FA 30%, #F5F3F0 100%);
  overflow: hidden;
}
.rp-header-bg {
  position: absolute;
  top: -50rpx;
  right: -30rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(99,102,241,0.06) 0%, transparent 70%);
}
.rp-header-content { position: relative; z-index: 1; }
.rp-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(99,102,241,0.1);
  border-radius: 9999rpx;
  margin-bottom: 24rpx;
}
.rp-badge-icon { font-size: 28rpx; }
.rp-badge-text { font-size: 22rpx; color: #6366F1; font-weight: 500; }
.rp-title { font-size: 44rpx; font-weight: 800; color: #1F2937; }
.rp-title-sub { font-size: 36rpx; font-weight: 700; color: #6366F1; margin-top: 4rpx; }
.rp-subtitle { font-size: 24rpx; color: #9CA3AF; margin-top: 12rpx; }
.rp-time { font-size: 24rpx; color: #9CA3AF; margin-top: 8rpx; }

/* ── Pet Card ── */
.pet-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: -24rpx 32rpx 16rpx;
  padding: 28rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  border-radius: 20rpx;
  background: #FFFFFF;
}
.pet-card-avatar .pet-avatar-img {
  width: 96rpx; height: 96rpx;
  border-radius: 50%;
  border: 3rpx solid #E0E7FF;
}
.pet-card-name { font-size: 34rpx; font-weight: 700; color: #1F2937; margin-bottom: 8rpx; }
.pet-card-meta { display: flex; gap: 12rpx; flex-wrap: wrap; }
.meta-tag {
  font-size: 22rpx; padding: 4rpx 14rpx;
  background: #F3F4F6; border-radius: 6rpx; color: #6B7280;
}

/* ── Sections ── */
.rp-section {
  margin: 16rpx 32rpx;
  padding: 28rpx;
  border-radius: 20rpx;
}
.rp-section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 16rpx;
}
.rp-section-subtitle { font-size: 24rpx; color: #9CA3AF; margin-bottom: 16rpx; }

/* Constitution type */
.rp-const-type {
  font-size: 40rpx;
  font-weight: 800;
  color: #6366F1;
}
.rp-core-state { color: #4B5563; line-height: 1.7; }
.rp-tags { display: flex; flex-wrap: wrap; gap: 12rpx; }
.rp-tag {
  padding: 8rpx 18rpx;
  background: #EEF2FF;
  color: #4F46E5;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* Mirror card */
.mirror-card { background: linear-gradient(135deg, #FFFFFF, #F8FAFF); border: 1rpx solid #E0E7FF; }
.mirror-item {
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #EEF2FF;
}
.mirror-item:last-child { margin-bottom: 0; }
.mirror-chain {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
}
.mirror-from { color: #6B7280; }
.mirror-arrow { color: #6366F1; font-size: 32rpx; }
.mirror-to { color: #4F46E5; }
.mirror-reason { color: #9CA3AF; line-height: 1.5; }
.mirror-adjust { color: #059669; line-height: 1.5; display: flex; gap: 6rpx; padding: 8rpx 12rpx; background: #F0FDF7; border-radius: 8rpx; }

/* Warnings */
.warning-item {
  padding: 18rpx;
  margin-bottom: 12rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
  border-left: 4rpx solid #EF4444;
}
.warning-item:last-child { margin-bottom: 0; }
.warning-label { font-size: 28rpx; font-weight: 700; color: #DC2626; margin-bottom: 8rpx; }
.warning-content { color: #6B7280; line-height: 1.6; }

/* Habits */
.habits-card { background: #FFFBEB; border: 1rpx solid #FDE68A; }
.habit-item { display: flex; gap: 10rpx; padding: 8rpx 0; color: #4B5563; line-height: 1.6; }
.rp-dot { font-weight: 700; font-size: 28rpx; color: #6366F1; flex-shrink: 0; }
.rp-dot.warning { color: #F59E0B; }
.rp-dot.danger { color: #EF4444; }

/* Science */
.science-card { background: #FAFFF5; border: 1rpx solid #D9F0D1; }
.science-item { padding: 8rpx 0; }
.science-title { font-size: 28rpx; font-weight: 700; color: #1A5A4E; margin-bottom: 8rpx; }

/* Convergence */
.convergence-list { padding: 4rpx 0; }

/* Shared Points */
.shared-item {
  display: flex;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.shared-item:last-child { border-bottom: none; }
.shared-emoji { font-size: 36rpx; flex-shrink: 0; width: 48rpx; text-align: center; }
.shared-text { color: #4B5563; line-height: 1.6; flex: 1; }

/* Care */
.care-group-title { font-size: 28rpx; font-weight: 700; color: #1F2937; margin: 12rpx 0 4rpx; }

/* Conclusion */
.conclusion-card { background: linear-gradient(135deg, #F0FDF7, #EEF2FF); border: 1rpx solid #BBF7D0; }
.conclusion-text { color: #374151; line-height: 1.8; }

/* Disclaimer + Actions (shared) */
.disclaimer {
  display: flex; gap: 16rpx;
  margin: 32rpx 32rpx 16rpx; padding: 24rpx;
  background: #FFFBEB; border: 1rpx solid #FDE68A; border-radius: 16rpx;
}
.disclaimer-icon { font-size: 36rpx; flex-shrink: 0; }
.disclaimer-text { flex: 1; }
.report-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
  padding: 16rpx 48rpx calc(16rpx + env(safe-area-inset-bottom));
}
.action-btn { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }

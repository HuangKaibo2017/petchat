.report-header {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(180deg, #FFF7ED, #FFFFFF);
}
.report-section { margin: 16rpx 32rpx; }
.section-label { font-size: 30rpx; font-weight: 700; color: #F97316; margin-bottom: 16rpx; }

.risk-card { background: #FFF5F5; border: 2rpx solid #FECACA; }
.risk-subsection { margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #FEE2E2; }
.risk-subsection:first-child { margin-top: 0; padding-top: 0; border-top: none; }
.risk-subtitle { color: #DC2626; margin-bottom: 4rpx; }

.disclaimer { margin: 24rpx 32rpx; padding: 16rpx; border-radius: 16rpx; }

.report-actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
  padding-bottom: env(safe-area-inset-bottom);
}
.action-btn { display: flex; flex-direction: column; align-items: center; gap: 4rpx; }

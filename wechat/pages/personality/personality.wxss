.page-container { padding-bottom: 48rpx; }
.intro-card { margin: 16rpx 32rpx 24rpx; padding: 32rpx 24rpx; text-align: center; background: linear-gradient(180deg, #EDE9FE, #F5F3FF); }
.intro-icon { font-size: 56rpx; margin-bottom: 16rpx; }

.form-card { margin: 0 32rpx; padding: 24rpx; }
.form-item { margin-bottom: 24rpx; }
.form-item:last-child { margin-bottom: 0; }
.form-label { color: #374151; margin-bottom: 12rpx; }
.form-input { width: 100%; padding: 16rpx 20rpx; background: #F9FAFB; border-radius: 12rpx; font-size: 28rpx; color: #1F2937; }
.paw-upload { width: 200rpx; height: 200rpx; border-radius: 16rpx; overflow:hidden; background:#F9FAFB; border: 2rpx dashed #D1D5DB; margin:0 auto; }
.paw-preview { width:100%; height:100%; }
.paw-hint { width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; color:#9CA3AF; }

.quiz-card { margin: 0 32rpx; padding: 24rpx; }
.quiz-progress {  }
.progress-bar { height: 8rpx; background: #F3F4F6; border-radius: 4rpx; overflow:hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #8B5CF6, #A78BFA); border-radius: 4rpx; transition: width 0.3s; }
.quiz-question { color: #1F2937; line-height: 1.6; }
.quiz-options { display:flex; flex-direction:column; gap: 12rpx; }
.quiz-option { display:flex; align-items:center; gap: 16rpx; padding: 20rpx 24rpx; border-radius: 14rpx; background: #F9FAFB; }
.option-selected { background: #EDE9FE; border: 2rpx solid #8B5CF6; }
.option-marker { width: 44rpx; height: 44rpx; border-radius: 50%; background: #E5E7EB; display:flex; align-items:center; justify-content:center; font-size: 22rpx; font-weight: 700; color: #6B7280; flex-shrink:0; }
.option-selected .option-marker { background: #8B5CF6; color: #fff; }

.report-card { margin: 0 32rpx; padding: 24rpx; }
.report-section { border-left: 4rpx solid #8B5CF6; padding-left: 16rpx; }
.chip-wrap { flex-wrap:wrap; gap: 12rpx; }
.personality-chip { padding: 8rpx 20rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #EDE9FE, #DDD6FE); color: #7C3AED; font-size: 24rpx; font-weight: 600; }
.radar-bars { display:flex; flex-direction:column; gap: 10rpx; }
.bar-bg { height: 12rpx; background: #F3F4F6; border-radius: 6rpx; overflow:hidden; }
.bar-fill { height: 100%; background: linear-gradient(90deg, #8B5CF6, #C084FC); border-radius: 6rpx; }
.blindbox-grid { display:grid; grid-template-columns: repeat(4,1fr); gap:12rpx; }
.blindbox-item { text-align:center; padding: 16rpx 8rpx; background: #F9FAFB; border-radius: 14rpx; }
.blindbox-emoji { font-size: 36rpx; margin-bottom: 8rpx; }
.blindbox-name { color: #374151; margin-bottom: 4rpx; }
.blindbox-price {  }

.section { margin-bottom: 32rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #1F2937; margin: 0 32rpx 16rpx; }

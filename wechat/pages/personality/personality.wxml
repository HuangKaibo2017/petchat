<nav-bar title="宠物性格分析" showBack="{{true}}" />
<view class="page-container">
  <view class="intro-card card">
    <view class="intro-icon">🧬</view>
    <view class="intro-title text-lg font-bold">宠物性格分析</view>
    <view class="intro-desc text-sm text-hint mt-sm">填写行为问卷、上传脚垫照片、输入出生日期和数字，生成性格标签与雷达画像，精准推荐盲盒玩具</view>
  </view>

  <!-- 步骤1：基本信息 -->
  <view class="section" wx:if="{{step===0}}">
    <view class="section-title">基本信息</view>
    <view class="form-card card">
      <view class="form-item">
        <view class="form-label text-sm font-bold">宠物名称</view>
        <input class="form-input" placeholder="请输入" value="{{petName}}" bindinput="onInput" data-field="petName" />
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">出生日期</view>
        <picker mode="date" value="{{birthDate}}" bindchange="onDateChange">
          <view class="form-input">{{birthDate || '请选择'}}</view>
        </picker>
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">感应数字 <text class="text-xs text-hint">· 1-9</text></view>
        <input class="form-input" type="number" placeholder="直觉数字" value="{{senseNum}}" bindinput="onInput" data-field="senseNum" maxlength="1" />
      </view>
      <view class="form-item">
        <view class="form-label text-sm font-bold">上传脚垫照片</view>
        <view class="paw-upload" bindtap="uploadPaw">
          <image class="paw-preview" src="{{pawImage}}" mode="aspectFill" wx:if="{{pawImage}}" />
          <view class="paw-hint" wx:else>
            <text class="text-3xl">🐾</text>
            <text class="text-xs text-hint mt-xs">点击上传脚垫照片</text>
          </view>
        </view>
      </view>
      <view class="btn btn-primary btn-block mt-md" bindtap="nextStep">下一步：行为问卷</view>
    </view>
  </view>

  <!-- 步骤2：行为问卷 -->
  <view class="section" wx:if="{{step===1}}">
    <view class="section-title">行为问卷 <text class="text-xs text-hint">· {{currentQ + 1}}/{{questions.length}}</text></view>
    <view class="quiz-card card">
      <view class="quiz-progress">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{(currentQ+1)/questions.length*100}}%"></view>
        </view>
      </view>
      <view class="quiz-question text-md font-bold mt-lg mb-lg">{{questions[currentQ].text}}</view>
      <view class="quiz-options">
        <view class="quiz-option {{answers[currentQ]===idx?'option-selected':''}}" wx:for="{{questions[currentQ].options}}" wx:key="index" wx:for-index="idx" bindtap="selectAnswer" data-q="{{currentQ}}" data-a="{{idx}}">
          <view class="option-marker">{{idx===0?'A':idx===1?'B':idx===2?'C':'D'}}</view>
          <text class="text-sm">{{item}}</text>
        </view>
      </view>
      <view class="quiz-nav flex-between mt-lg">
        <view class="btn btn-outline btn-sm" bindtap="prevQ" wx:if="{{currentQ > 0}}">上一题</view>
        <view></view>
        <view class="btn btn-primary btn-sm" bindtap="nextQ" wx:if="{{currentQ < questions.length - 1}}">下一题</view>
        <view class="btn btn-primary btn-sm" bindtap="generateReport" wx:if="{{currentQ === questions.length - 1}}">🔮 生成性格报告</view>
      </view>
    </view>
  </view>

  <!-- 报告结果 -->
  <view class="section" wx:if="{{report}}">
    <view class="report-card card">
      <!-- 性格标签 -->
      <view class="report-section" wx:if="{{report.tags}}">
        <view class="text-md font-bold mb-sm">🏷️ 性格标签</view>
        <view class="flex chip-wrap">
          <view class="personality-chip" wx:for="{{report.tags}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
      <!-- 雷达画像描述 -->
      <view class="report-section mt-md" wx:if="{{report.radarDesc}}">
        <view class="text-md font-bold mb-sm">📊 雷达画像</view>
        <view class="radar-bars">
          <view class="radar-bar" wx:for="{{report.radarScores}}" wx:key="label" wx:for-item="s">
            <view class="flex-between items-center mb-xs">
              <text class="text-xs">{{s.label}}</text>
              <text class="text-xs text-primary">{{s.score}}%</text>
            </view>
            <view class="bar-bg"><view class="bar-fill" style="width:{{s.score}}%"></view></view>
          </view>
        </view>
        <view class="text-sm text-hint mt-sm">{{report.radarDesc}}</view>
      </view>
      <!-- 家庭地位 -->
      <view class="report-section mt-md" wx:if="{{report.familyRole}}">
        <view class="text-md font-bold mb-sm">👑 家庭地位</view>
        <view class="text-sm text-hint">{{report.familyRole}}</view>
      </view>
      <!-- 盲盒推荐 -->
      <view class="report-section mt-md" wx:if="{{report.blindBoxes}}">
        <view class="text-md font-bold mb-sm">🎁 盲盒玩具推荐</view>
        <view class="blindbox-grid">
          <view class="blindbox-item" wx:for="{{report.blindBoxes}}" wx:key="id">
            <view class="blindbox-emoji">{{item.emoji}}</view>
            <view class="blindbox-name text-xs font-bold">{{item.name}}</view>
            <view class="blindbox-price text-xs text-primary">¥{{item.price}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
<nav-bar title="{{petName}}" showBack="{{true}}" />

<!-- 宠物虚拟形象区域 -->
<view class="pet-avatar-zone">
  <view class="pet-avatar-ring">
    <image class="pet-avatar-chat" src="{{petAvatar || '/images/default-pet.png'}}" mode="aspectFill" />
    <!-- 互动特效 -->
    <view class="pet-reaction" wx:if="{{petReaction}}" animation="{{reactionAnim}}">{{petReaction}}</view>
  </view>
  <view class="pet-status-bar flex items-center justify-center mt-sm">
    <view class="pet-status-item" bindtap="petPetting">
      <text class="text-2xl">🤚</text>
      <text class="text-xs text-hint mt-xs">抚摸</text>
    </view>
    <view class="pet-status-item" bindtap="petFeeding">
      <text class="text-2xl">🍖</text>
      <text class="text-xs text-hint mt-xs">投喂</text>
    </view>
    <view class="pet-status-item" bindtap="goIoTBind">
      <text class="text-2xl">🏠</text>
      <text class="text-xs text-hint mt-xs">智能家居</text>
    </view>
  </view>
</view>

<scroll-view class="chat-scroll" scroll-y scroll-into-view="{{scrollToId}}" scroll-with-animation>
  <view class="chat-messages" id="chatMessages">
    <view wx:for="{{messages}}" wx:key="id" class="msg-wrap {{item.role === 'pet' ? 'left' : 'right'}}" id="msg-{{item.id}}">
      <image wx:if="{{item.role === 'pet'}}" class="avatar-sm" src="{{petAvatar || '/images/default-pet.png'}}" mode="aspectFill" />
      <view class="msg-bubble {{item.role === 'pet' ? 'pet' : 'user'}}">
        {{item.content}}<text wx:if="{{item.streaming}}" class="stream-cursor">▌</text>
      </view>
      <image wx:if="{{item.role === 'user'}}" class="avatar-sm" src="{{userAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
    </view>
  </view>
</scroll-view>

<view class="chat-input-bar safe-bottom" style="bottom: {{keyboardHeight}}px;">
  <input class="chat-input" placeholder="输入消息…" value="{{inputText}}" bindinput="onInput" bindconfirm="sendMessage" confirm-type="send" disabled="{{sending}}" bindkeyboardheightchange="onKeyboardHeightChange" />
  <view class="send-btn" bindtap="sendMessage">发送</view>
</view>
/* 宠物虚拟形象区 */
.pet-avatar-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 16rpx;
  background: linear-gradient(180deg, #FAF9F5 0%, #FFFFFF 100%);
}
.pet-avatar-ring {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #2D7D6E;
  padding: 6rpx;
  background: linear-gradient(135deg, #D8EBE6, #A7D8C8);
}
.pet-avatar-chat {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.pet-reaction {
  position: absolute;
  top: -20rpx;
  right: -10rpx;
  font-size: 40rpx;
}

.pet-status-bar {
  gap: 48rpx;
  padding: 8rpx 0;
}
.pet-status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.15s;
}
.pet-status-item:active {
  background: #F3F4F6;
  transform: scale(0.95);
}

.chat-scroll {
  height: calc(100vh - 380rpx);
  background: #F5F5F5;
}
.chat-messages {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
}
.msg-wrap {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  gap: 12rpx;
}
.msg-wrap.right {
  flex-direction: row-reverse;
}
.avatar-sm {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.msg-bubble {
  max-width: 70%;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}
.msg-bubble.pet {
  background: #FFFFFF;
  color: #1F2937;
  border-top-left-radius: 6rpx;
}
.msg-bubble.user {
  background: #2D7D6E;
  color: #FFFFFF;
  border-top-right-radius: 6rpx;
}
.stream-cursor {
  animation: blink 1s infinite;
}
@keyframes blink {
  0%, 50% { opacity: 1; }
  50.1%, 100% { opacity: 0; }
}

.chat-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #FFFFFF;
  border-top: 1rpx solid #F3F4F6;
  gap: 16rpx;
}
.chat-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.send-btn {
  width: 120rpx;
  height: 72rpx;
  background: #2D7D6E;
  border-radius: 36rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

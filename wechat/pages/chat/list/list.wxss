.chat-scroll {
  height: 100vh;
  padding-bottom: 120rpx;
}
.chat-messages {
  padding: 16rpx 24rpx;
  padding-bottom: 20rpx;
}
.msg-wrap { display: flex; align-items: flex-start; margin-bottom: 24rpx; gap: 12rpx; }
.msg-wrap.right { flex-direction: row-reverse; }
.msg-bubble { max-width: 70%; padding: 16rpx 20rpx; border-radius: 20rpx; font-size: 28rpx; line-height: 1.5; }
.msg-bubble.pet { background: #D8EBE6; color: #1F2937; border-top-left-radius: 4rpx; }
.msg-bubble.user { background: linear-gradient(135deg, #2D7D6E, #5BA89A); color: #FFFFFF; border-top-right-radius: 4rpx; }
.stream-cursor {
  animation: blink 1s step-end infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}
.chat-input-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; align-items: center; gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
  z-index: 100;
}
.chat-input {
  flex: 1; background: #F3F4F6; border-radius: 9999rpx; padding: 16rpx 24rpx; font-size: 28rpx;
}
.send-btn {
  padding: 16rpx 32rpx; background: #2D7D6E; color: #FFFFFF; border-radius: 9999rpx; font-size: 28rpx; font-weight: 500;
}

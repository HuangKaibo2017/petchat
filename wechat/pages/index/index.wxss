/* ═══════════════════════════════════════════
   Index Page — 更懂它 首页（重构版）
   ═══════════════════════════════════════════ */

/* ─── 宠物状态卡 ─── */
.pet-status-card {
  margin: 16rpx 32rpx 8rpx;
}
.nfc-icon {
  margin-left: 16rpx;
  padding: 4rpx 16rpx;
  background: #F3F4F6;
  border-radius: 9999rpx;
}
.add-pet-card {
  margin: 16rpx 32rpx;
  padding: 48rpx 32rpx;
}

/* ═══════════════════════════════════════════
   1. Banner 分区
   ═══════════════════════════════════════════ */
.banner-swiper {
  height: 240rpx;
  margin: 0 32rpx;
  border-radius: 24rpx;
  overflow: hidden;
}
.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 32rpx;
  position: relative;
}
.banner-content { flex: 1; z-index: 1; }
.banner-tag { margin-bottom: 12rpx; }
.banner-title { color: #FFFFFF; margin-bottom: 8rpx; }
.banner-desc { color: rgba(255,255,255,0.8); }
.banner-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
}

/* ═══════════════════════════════════════════
   2. 核心工具网格（3 列）
   ═══════════════════════════════════════════ */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  padding: 0 32rpx;
}
.tool-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.tool-hover {
  transform: scale(0.96);
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.12);
}
.tool-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}
.tool-name {
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 4rpx;
}
.tool-desc { display: block; }

/* ═══════════════════════════════════════════
   3. 水印照片
   ═══════════════════════════════════════════ */
.photo-zone {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
}
.photo-card {
  flex: 1;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.photo-card:active { transform: scale(0.97); }
.photo-card-inner {
  padding: 28rpx 16rpx 20rpx;
  text-align: center;
}
.photo-emoji { font-size: 40rpx; margin-bottom: 10rpx; }
.photo-label { color: #1F2937; margin-bottom: 4rpx; }
.photo-hint { display: block; }
.photo-watermark { background: linear-gradient(180deg, #FEF3C7 0%, #FFFFFF 100%); }
.photo-comic { background: linear-gradient(180deg, #E0E7FF 0%, #FFFFFF 100%); }
.photo-series { background: linear-gradient(180deg, #FCE7F3 0%, #FFFFFF 100%); }

/* ═══════════════════════════════════════════
   4. 救助专区
   ═══════════════════════════════════════════ */
.rescue-entry {
  margin: 0 32rpx;
  padding: 24rpx;
}
.rescue-entry-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}
.rescue-sub-actions { gap: 16rpx; }
.rescue-sub-btn {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 14rpx;
  background: #F9FAFB;
  color: #374151;
  transition: all 0.15s;
}
.rescue-sub-btn:active { background: #F3F4F6; }

/* ─── 公用 ─── */
.section { margin-bottom: 32rpx; }
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin: 0 32rpx 16rpx;
}
.section-header {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

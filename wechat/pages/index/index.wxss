/* ═══════════════════════════════════════════
   Index — 复刻设计稿
   ═══════════════════════════════════════════ */

.idx-page {
  min-height: 100vh;
  background: #FBF9F2;
  padding-top: 0;
}

/* ─── 品牌头部 ─── */
.idx-brand {
  padding-top: calc(88rpx + env(safe-area-inset-top));
  padding-right: 32rpx;
  padding-bottom: 40rpx;
  padding-left: 32rpx;
  text-align: center;
  background: linear-gradient(180deg, #FFF8ED 0%, #FBF9F2 100%);
}
.idx-brand-title {
  font-size: 64rpx;
  font-weight: 800;
  color: #3D2C1E;
  letter-spacing: 16rpx;
  margin-bottom: 8rpx;
}
.idx-brand-slogan {
  font-size: 26rpx;
  color: #A89789;
  letter-spacing: 4rpx;
}

/* ─── 通用分区 ─── */
.idx-section {
  padding: 32rpx 32rpx 0;
}
.idx-section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #3D2C1E;
  margin-bottom: 20rpx;
  position: relative;
  padding-left: 20rpx;
}
.idx-section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 26rpx;
  border-radius: 3rpx;
  background: #C8A87C;
}
.idx-section-subtitle {
  font-size: 24rpx;
  color: #A89789;
  margin-bottom: 20rpx;
  margin-top: -12rpx;
  text-align: center;
}

/* ═══════════════════════════════════════════
   核心工具 — 3 卡横排
   ═══════════════════════════════════════════ */
.idx-tools {
  display: flex;
  gap: 20rpx;
}
.idx-tool {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 16rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}
.idx-tool:active { transform: scale(0.96); }
.idx-tool-icon {
  font-size: 44rpx;
  margin-bottom: 12rpx;
  display: block;
}
.idx-tool-name {
  font-size: 24rpx;
  font-weight: 700;
  color: #3D2C1E;
  margin-bottom: 6rpx;
}
.idx-tool-desc {
  font-size: 20rpx;
  color: #A89789;
  line-height: 1.4;
}

/* ═══════════════════════════════════════════
   水印照片
   ═══════════════════════════════════════════ */
.idx-watermark {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.idx-watermark-input-wrap {
  flex: 1;
}
.idx-watermark-input {
  width: 100%;
  height: 80rpx;
  background: #F5F3ED;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #3D2C1E;
  box-sizing: border-box;
}
.idx-watermark-input::placeholder {
  color: #C4B8AD;
}
.idx-watermark-upload {
  flex-shrink: 0;
}
.idx-watermark-camera {
  width: 100rpx;
  height: 80rpx;
  background: #F5F3ED;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.idx-watermark-camera-icon {
  font-size: 36rpx;
}

/* ═══════════════════════════════════════════
   救助专区 — 双卡
   ═══════════════════════════════════════════ */
.idx-rescue {
  display: flex;
  gap: 20rpx;
}
.idx-rescue-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}
.idx-rescue-card:active { transform: scale(0.96); }
.idx-rescue-card-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FEF3C7, #FDE68A);
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.idx-rescue-emoji {
  font-size: 36rpx;
}
.idx-rescue-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #3D2C1E;
  margin-bottom: 8rpx;
}
.idx-rescue-hint {
  font-size: 22rpx;
  color: #A89789;
}

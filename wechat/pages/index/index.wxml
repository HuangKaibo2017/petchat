<nav-bar title="PetChat 灵犀" />
<view class="page-container">
  <!-- Brand Hero -->
  <view class="hero-section">
    <image class="hero-bg" src="/images/hero-bg.png" mode="aspectFill" />
    <view class="hero-overlay">
      <view class="hero-brand text-3xl font-bold">PetChat 灵犀</view>
      <view class="hero-slogan text-md">懂宠物，更懂你</view>
    </view>
  </view>

  <!-- Current Pet Status (NFC quick glance) -->
  <view class="pet-status-card card" wx:if="{{currentPet}}">
    <view class="flex-between">
      <view class="flex items-center">
        <image class="avatar-md" src="{{currentPet.avatar || '/images/default-pet.png'}}" mode="aspectFill" />
        <view class="ml-sm">
          <view class="font-bold text-lg">{{currentPet.name}}</view>
          <view class="text-xs text-hint">{{currentPet.breed}} · {{currentPet.age}}</view>
        </view>
      </view>
      <view class="flex items-center">
        <view class="status-tag tag tag-{{currentPet.mood || 'success'}}">{{currentPet.moodText || '状态良好'}}</view>
        <view class="nfc-icon" wx:if="{{nfcEnabled}}">
          <text class="text-xs text-hint">NFC</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Quick Add Pet if no pet -->
  <view class="add-pet-card card text-center" wx:if="{{!currentPet && !pets.length}}" bindtap="goRegister">
    <view class="text-lg text-hint mb-sm">🐾 还未添加宠物</view>
    <view class="text-sm text-muted">添加宠物档案，开启智能养护之旅</view>
    <view class="btn btn-primary btn-sm mt-md" style="display:inline-flex">立即添加</view>
  </view>

  <!-- Core Service Grid -->
  <view class="section">
    <view class="section-title">核心服务</view>
    <view class="service-grid">
      <view class="service-item" bindtap="goEmotion" hover-class="service-hover">
        <view class="service-icon emotion-icon">🔮</view>
        <view class="service-name text-sm">宠物心声解读</view>
        <view class="service-desc text-xs text-hint">卦象解读情绪</view>
      </view>
      <view class="service-item" bindtap="goHealth" hover-class="service-hover">
        <view class="service-icon health-icon">💊</view>
        <view class="service-name text-sm">宠物健康监测</view>
        <view class="service-desc text-xs text-hint">双卦复合分析</view>
      </view>
      <view class="service-item" bindtap="goPersonality" hover-class="service-hover">
        <view class="service-icon personality-icon">🧬</view>
        <view class="service-name text-sm">宠物性格分析</view>
        <view class="service-desc text-xs text-hint">五行体质洞见</view>
      </view>
      <view class="service-item" bindtap="goRisk" hover-class="service-hover">
        <view class="service-icon risk-icon">⚡</view>
        <view class="service-name text-sm">人宠风险预警</view>
        <view class="service-desc text-xs text-hint">双向守护</view>
      </view>
      <view class="service-item" bindtap="goMedical" hover-class="service-hover">
        <view class="service-icon medical-icon">📋</view>
        <view class="service-name text-sm">临床用药科普</view>
        <view class="service-desc text-xs text-hint">AI知识库</view>
      </view>
      <view class="service-item" bindtap="goNewPet" hover-class="service-hover">
        <view class="service-icon newpet-icon">🐣</view>
        <view class="service-name text-sm">新宠购买指南</view>
        <view class="service-desc text-xs text-hint">避坑建议</view>
      </view>
      <view class="service-item" bindtap="goMimicChat" hover-class="service-hover">
        <view class="service-icon chat-icon">💬</view>
        <view class="service-name text-sm">拟态聊天</view>
        <view class="service-desc text-xs text-hint">宠物视角对话</view>
      </view>
      <view class="service-item" bindtap="goLostPet" hover-class="service-hover">
        <view class="service-icon lost-icon">🧭</view>
        <view class="service-name text-sm">丢失方向建议</view>
        <view class="service-desc text-xs text-hint">方向指引</view>
      </view>
      <view class="service-item" bindtap="goRescue" hover-class="service-hover">
        <view class="service-icon rescue-icon">🏠</view>
        <view class="service-name text-sm">救助专区</view>
        <view class="service-desc text-xs text-hint">领养·救助</view>
      </view>
    </view>
  </view>

  <!-- Banner Carousel -->
  <view class="section">
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#F97316" autoplay circular interval="4000">
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <view class="banner-item" style="background: {{item.bg}}" bindtap="onBannerTap" data-url="{{item.url}}">
          <view class="banner-content">
            <view class="banner-tag tag" wx:if="{{item.tag}}">{{item.tag}}</view>
            <view class="banner-title text-lg font-bold">{{item.title}}</view>
            <view class="banner-desc text-sm">{{item.desc}}</view>
          </view>
          <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- Hospital Recommendations -->
  <view class="section">
    <view class="flex-between mb-sm">
      <view class="section-title" style="margin-bottom:0">附近医院</view>
      <view class="text-sm text-primary" bindtap="goHospitals">查看全部 ›</view>
    </view>
    <scroll-view scroll-x class="hospital-scroll">
      <view class="hospital-item card" wx:for="{{nearHospitals}}" wx:key="id" bindtap="goHospitalDetail" data-id="{{item.id}}">
        <view class="hospital-name font-bold text-md">{{item.name}}</view>
        <view class="flex items-center mt-sm">
          <text class="text-warning text-sm">⭐ {{item.rating}}</text>
          <text class="text-hint text-xs ml-sm">{{item.distance}}</text>
        </view>
        <view class="hospital-tags flex mt-sm">
          <text class="tag tag-primary text-xs" wx:for="{{item.tags}}" wx:key="*this" wx:for-item="t">{{t}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Recommend Products -->
  <view class="section">
    <view class="flex-between mb-sm">
      <view class="section-title" style="margin-bottom:0">灵犀好物</view>
      <view class="text-sm text-primary" bindtap="goShop">更多 ›</view>
    </view>
    <view class="grid-2">
      <view class="product-mini" wx:for="{{recommendProducts}}" wx:key="id" bindtap="goProductDetail" data-id="{{item.id}}">
        <image class="product-img" src="{{item.image}}" mode="aspectFill" />
        <view class="product-name text-sm">{{item.name}}</view>
        <view class="product-price text-primary font-bold text-md">¥{{item.price}}</view>
      </view>
    </view>
  </view>

  <!-- Bottom spacing for tab bar -->
  <view style="height: 120rpx"></view>
</view>

<authorize visible="{{showAuth}}" bind:success="onAuthSuccess" bind:cancel="onAuthCancel" />

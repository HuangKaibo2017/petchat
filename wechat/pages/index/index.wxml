<nav-bar title="更懂它" />
<view class="page-container">
  <!-- ===== 0. 宠物状态卡 ===== -->
  <view class="pet-status-card card" wx:if="{{currentPet}}">
    <view class="flex-between">
      <view class="flex items-center">
        <image class="avatar-md" src="{{currentPet.avatar || '/images/default-pet.png'}}" mode="aspectFill" />
        <view class="ml-sm">
          <view class="font-bold text-lg">{{currentPet.name}}</view>
          <view class="text-xs text-hint">{{currentPet.breed}} · {{currentPet.age}}</view>
        </view>
      </view>
      <view class="flex items-center">
        <view class="status-tag tag tag-{{currentPet.mood || 'success'}}">{{currentPet.moodText || '状态良好'}}</view>
        <view class="nfc-icon" wx:if="{{nfcEnabled}}">
          <text class="text-xs text-hint">NFC</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 未添加宠物引导 -->
  <view class="add-pet-card card text-center" wx:if="{{!currentPet && !pets.length}}">
    <view class="text-lg text-hint mb-sm">🐾 还未添加宠物</view>
    <view class="text-sm text-muted">添加宠物档案，开启智能养护之旅</view>
    <view class="btn btn-primary btn-sm mt-md inline-flex" bindtap="goRegister">立即添加</view>
  </view>

  <!-- ===== 1. Banner (3:1 比例) ===== -->
  <view class="section">
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#F97316" autoplay circular interval="4000">
      <swiper-item wx:for="{{majorBanners}}" wx:key="id">
        <view class="banner-item" style="background: {{item.bg}}" bindtap="onBannerTap" data-url="{{item.url}}">
          <view class="banner-content">
            <view class="banner-tag tag" wx:if="{{item.tag}}">{{item.tag}}</view>
            <view class="banner-title text-xl font-bold">{{item.title}}</view>
            <view class="banner-desc text-sm">{{item.desc}}</view>
          </view>
          <image class="banner-img" src="{{item.image}}" mode="aspectFit" wx:if="{{item.image}}" />
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- ===== 2. 核心工具 (7 项) ===== -->
  <view class="section">
    <view class="section-title">核心工具</view>
    <view class="tool-grid">
      <view class="tool-item" bindtap="goHealth" hover-class="tool-hover">
        <view class="tool-icon">💊</view>
        <view class="tool-name text-sm">宠物体质分析</view>
        <view class="tool-desc text-xs text-hint">五运六气综合</view>
      </view>
      <view class="tool-item" bindtap="goEmotion" hover-class="tool-hover">
        <view class="tool-icon">🔮</view>
        <view class="tool-name text-sm">宠物心声解读</view>
        <view class="tool-desc text-xs text-hint">多维度·一事一问</view>
      </view>
      <view class="tool-item" bindtap="goPersonality" hover-class="tool-hover">
        <view class="tool-icon">🧬</view>
        <view class="tool-name text-sm">宠物性格分析</view>
        <view class="tool-desc text-xs text-hint">雷达画像盲盒</view>
      </view>
      <view class="tool-item" bindtap="goRisk" hover-class="tool-hover">
        <view class="tool-icon">⚡</view>
        <view class="tool-name text-sm">人宠风险预警</view>
        <view class="tool-desc text-xs text-hint">情绪同频·菌群</view>
      </view>
      <view class="tool-item" bindtap="goMedical" hover-class="tool-hover">
        <view class="tool-icon">📋</view>
        <view class="tool-name text-sm">临床用药科普</view>
        <view class="tool-desc text-xs text-hint">Coze智能体</view>
      </view>
      <view class="tool-item" bindtap="goNewPet" hover-class="tool-hover">
        <view class="tool-icon">🐣</view>
        <view class="tool-name text-sm">新宠购买指南</view>
        <view class="tool-desc text-xs text-hint">成本测算避坑</view>
      </view>
      <view class="tool-item" bindtap="goLostPet" hover-class="tool-hover">
        <view class="tool-icon">🧭</view>
        <view class="tool-name text-sm">丢失方向建议</view>
        <view class="tool-desc text-xs text-hint">数字卦寻宠</view>
      </view>
    </view>
  </view>

  <!-- ===== 3. 水印照片 ===== -->
  <view class="section">
    <view class="flex-between items-center section-header">
      <view class="section-title mb-0">水印照片</view>
      <view class="text-xs text-primary" bindtap="goPhoto">制作 ›</view>
    </view>
    <view class="photo-zone">
      <view class="photo-card photo-watermark" bindtap="goPhoto">
        <view class="photo-card-inner">
          <view class="photo-emoji">📸</view>
          <view class="photo-label text-sm font-bold">文字水印</view>
          <view class="photo-hint text-xs text-hint">一句话+日期</view>
        </view>
      </view>
      <view class="photo-card photo-comic" bindtap="goPhoto">
        <view class="photo-card-inner">
          <view class="photo-emoji">🎨</view>
          <view class="photo-label text-sm font-bold">漫画风格</view>
          <view class="photo-hint text-xs text-hint">宠物插画风</view>
        </view>
      </view>
      <view class="photo-card photo-series" bindtap="goPhoto">
        <view class="photo-card-inner">
          <view class="photo-emoji">🖼️</view>
          <view class="photo-label text-sm font-bold">系列模板</view>
          <view class="photo-hint text-xs text-hint">多款可选</view>
        </view>
      </view>
    </view>
  </view>

  <!-- ===== 4. 救助专区 ===== -->
  <view class="section">
    <view class="rescue-entry card" bindtap="goRescue">
      <view class="flex-between items-center">
        <view class="flex items-center">
          <view class="rescue-entry-icon">🐾</view>
          <view class="ml-md">
            <view class="text-md font-bold">救助专区</view>
            <view class="text-xs text-hint">流浪求助 · 宠物领养 · 志愿者招募</view>
          </view>
        </view>
        <view class="flex items-center">
          <view class="tag tag-primary" wx:if="{{rescueStats}}">
            <text>{{rescueStats.activeCount || 0}}个待救助</text>
          </view>
          <text class="text-lg text-hint ml-sm">›</text>
        </view>
      </view>
      <view class="rescue-sub-actions flex mt-md">
        <view class="rescue-sub-btn" catchtap="goRescueHelp">
          <text class="text-sm">💚 寻求帮助</text>
        </view>
        <view class="rescue-sub-btn" catchtap="goRescueAdopt">
          <text class="text-sm">🐕 领养宠物</text>
        </view>
        <view class="rescue-sub-btn" catchtap="goRescueDonate">
          <text class="text-sm">🎁 捐赠积分</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部间距 -->
  <view style="height: 40rpx"></view>
</view>

<authorize wx:if="{{showAuth}}" bind:success="onAuthSuccess" />

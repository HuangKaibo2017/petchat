<view class="idx-page">
  <!-- ═══ 品牌头部 ═══ -->
  <view class="idx-brand">
    <view class="idx-brand-title">更懂它</view>
    <view class="idx-brand-slogan">更懂它的心，陪它一生长久</view>
  </view>

  <!-- ═══ 核心工具（3 项） ═══ -->
  <view class="idx-section">
    <view class="idx-section-title">核心工具</view>
    <view class="idx-tools">
      <view class="idx-tool" bindtap="goEmotion">
        <view class="idx-tool-icon">🔮</view>
        <view class="idx-tool-name">宠物心声解读</view>
        <view class="idx-tool-desc">读懂它的情绪与需求</view>
      </view>
      <view class="idx-tool" bindtap="goMedical">
        <view class="idx-tool-icon">📋</view>
        <view class="idx-tool-name">宠物疾病科普</view>
        <view class="idx-tool-desc">科学养护，预防先行</view>
      </view>
      <view class="idx-tool" bindtap="goRisk">
        <view class="idx-tool-icon">⚡</view>
        <view class="idx-tool-name">人宠风险预警</view>
        <view class="idx-tool-desc">提前预警，安心相伴</view>
      </view>
    </view>
  </view>

  <!-- ═══ 水印照片 ═══ -->
  <view class="idx-section">
    <view class="idx-section-title">水印照片</view>
    <view class="idx-watermark">
      <view class="idx-watermark-input-wrap">
        <input class="idx-watermark-input" placeholder="写一句20字以内的话" maxlength="20" value="{{watermarkText}}" bindinput="onWatermarkInput" />
      </view>
      <view class="idx-watermark-upload" bindtap="goPhoto">
        <view class="idx-watermark-camera">
          <text class="idx-watermark-camera-icon">📷</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ═══ 救助专区 ═══ -->
  <view class="idx-section">
    <view class="idx-section-title">救助专区</view>
    <view class="idx-section-subtitle">汇聚爱心力量，守护每一个生命奇迹</view>
    <view class="idx-rescue">
      <view class="idx-rescue-card" bindtap="goRescueHelp">
        <view class="idx-rescue-card-img">
          <text class="idx-rescue-emoji">🐾</text>
        </view>
        <view class="idx-rescue-label">流浪求助</view>
        <view class="idx-rescue-hint">发现流浪，紧急求助</view>
      </view>
      <view class="idx-rescue-card" bindtap="goRescueAdopt">
        <view class="idx-rescue-card-img">
          <text class="idx-rescue-emoji">🏠</text>
        </view>
        <view class="idx-rescue-label">宠物领养</view>
        <view class="idx-rescue-hint">给它一个温暖的家</view>
      </view>
    </view>
  </view>

  <!-- ═══ 底部间距 ═══ -->
  <view style="height:80rpx"></view>
</view>

<authorize wx:if="{{showAuth}}" bind:success="onAuthSuccess" />

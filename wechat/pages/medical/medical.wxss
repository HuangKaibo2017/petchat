/* Mode selection */
.mode-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.mode-card {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.mode-icon {
  font-size: 48rpx;
}
.mode-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.mode-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

/* Constitution form */
.form-group {
  margin-bottom: 10rpx;
}
.form-label {
  font-size: 28rpx;
  color: #555;
  margin-bottom: 10rpx;
  font-weight: 500;
}
.picker-field {
  display: flex;
  align-items: center;
  height: 80rpx;
  color: #333;
}
.pet-info-card {
  padding: 24rpx;
  background: #f8faf9;
  border-radius: 12rpx;
}
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 8rpx 0;
  font-size: 26rpx;
}
.info-key {
  color: #999;
}
.info-val {
  color: #333;
  font-weight: 500;
}
.number-inputs {
  display: flex;
  gap: 16rpx;
}
.number-input {
  flex: 1;
  text-align: center;
}

/* Follow-up questions */
.followup-section {
  border-top: 2rpx solid #ECEAE5;
  padding-top: 32rpx;
}
.followup-q-text {
  color: #374151;
}
.followup-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.followup-opt {
  padding: 10rpx 22rpx;
  background: #F3F4F6;
  border-radius: 9999rpx;
  font-size: 26rpx;
  color: #6B7280;
  border: 2rpx solid transparent;
}
.opt-selected {
  background: #D8EBE6;
  color: #2D7D6E;
  border-color: #2D7D6E;
  font-weight: 500;
}

/* Image preview */
.image-preview {
  border-radius: 12rpx;
  overflow: hidden;
  width: 200rpx;
  height: 200rpx;
}
.preview-img {
  width: 100%;
  height: 100%;
}

/* Button outline style */
.btn-outline {
  background: transparent;
  border: 2rpx solid #2D7D6E;
  color: #2D7D6E;
}

<nav-bar title="科普指南" showBack="{{true}}" />
<view class="page-container">
  <view class="report-section card" wx:if="{{guide.summary || guide.guide}}">
    <view class="section-label">📋 分析结果</view>
    <view class="text-md">{{guide.summary || '根据症状描述，可能涉及消化系统不适或环境应激反应。'}}</view>
    <block wx:if="{{guide.guide}}">
      <view wx:for="{{guide.guide}}" wx:key="title" class="mt-md">
        <view class="text-md font-bold">{{item.title}}</view>
        <view class="text-sm text-muted mt-sm">{{item.desc}}</view>
      </view>
    </block>
  </view>
  <view class="report-section card" wx:if="{{guide.careAdvice}}">
    <view class="section-label">🏠 居家护理</view>
    <view class="text-md">{{guide.careAdvice}}</view>
  </view>
  <view class="report-section card" wx:if="{{guide.dosage}}">
    <view class="section-label">💊 科普剂量（仅供参考）</view>
    <view class="text-md">{{guide.dosage}}</view>
  </view>
  <view class="report-section card" wx:if="{{guide.hospitalAdvice}}">
    <view class="section-label">🏥 就医建议</view>
    <view class="text-md">{{guide.hospitalAdvice}}</view>
  </view>
  <view class="report-section card" wx:if="{{guide.exams}}">
    <view class="section-label">🔬 建议检查项目</view>
    <view class="text-md">{{guide.exams}}</view>
  </view>
  <view class="disclaimer card bg-primary-light">
    <view class="text-xs text-hint text-center">⚠️ 所有用药遵医嘱，本平台不提供诊疗服务</view>
  </view>
</view>

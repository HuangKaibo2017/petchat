/* ══════════════════════════════════════
   体质综合分析报告 — 中医体质风
   ══════════════════════════════════════ */

/* ── Header ── */
.const-header {
  position: relative;
  padding: 60rpx 40rpx 48rpx;
  background: linear-gradient(160deg, #E8F0EB 0%, #D4E5DC 30%, #F5F0E8 100%);
  overflow: hidden;
}
.const-header-bg {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(45,125,110,0.08) 0%, transparent 70%);
}
.const-header-content {
  position: relative;
  z-index: 1;
}
.const-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(45,125,110,0.12);
  border-radius: 9999rpx;
  margin-bottom: 24rpx;
}
.const-badge-icon { font-size: 28rpx; }
.const-badge-text { font-size: 22rpx; color: #2D7D6E; font-weight: 500; }
.const-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1F2937;
  letter-spacing: 4rpx;
}
.const-title-sub {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D7D6E;
  margin-top: 4rpx;
}
.const-time {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 16rpx;
}

/* ── Pet Info Card ── */
.pet-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: -24rpx 32rpx 16rpx;
  padding: 28rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  border-radius: 20rpx;
  background: #FFFFFF;
}
.pet-card-avatar .pet-avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 3rpx solid #D8EBE6;
}
.pet-card-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 8rpx;
}
.pet-card-meta {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 4rpx;
}
.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  background: #F3F4F6;
  border-radius: 6rpx;
  color: #6B7280;
}
.meta-tag.muted { color: #9CA3AF; }

/* ── Base Info ── */
.section-baseinfo {
  margin: 16rpx 32rpx;
  padding: 28rpx;
  border-left: 6rpx solid #2D7D6E;
}
.baseinfo-row {
  padding: 8rpx 0;
  color: #4B5563;
  line-height: 1.8;
}

/* ── Sections ── */
.const-section {
  margin: 20rpx 32rpx;
  padding: 32rpx 28rpx;
  border-radius: 20rpx;
}
.section-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.section-icon { font-size: 36rpx; }

/* ── Dimension List ── */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}
.dimension-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: #FAFCFA;
  border-radius: 14rpx;
  border: 1rpx solid #ECF5F0;
}
.dim-number {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2D7D6E, #4CA89A);
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.dim-text { flex: 1; }
.dim-title {
  font-size: 27rpx;
  color: #374151;
  line-height: 1.7;
  font-weight: 500;
}

/* ── Risk Rows ── */
.risk-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}
.risk-high {
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
}
.risk-mid {
  background: #FFFBEB;
  border: 1rpx solid #FDE68A;
}
.risk-good {
  background: #F0FDF4;
  border: 1rpx solid #BBF7D0;
}
.risk-emoji { font-size: 32rpx; flex-shrink: 0; }
.risk-body { flex: 1; }
.risk-label { font-size: 28rpx; font-weight: 700; color: #1F2937; }
.risk-content { color: #6B7280; line-height: 1.6; }

/* ── Problem Blocks ── */
.problem-block {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #FFFBF5;
  border-radius: 14rpx;
  border-left: 4rpx solid #F59E0B;
}
.problem-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #92400E;
  margin-bottom: 10rpx;
}
.problem-content {
  color: #6B7280;
  line-height: 1.7;
  margin-bottom: 8rpx;
}
.problem-item {
  display: flex;
  gap: 8rpx;
  padding: 4rpx 0;
  color: #4B5563;
  line-height: 1.6;
}
.problem-dot { color: #F59E0B; font-weight: 700; }

/* ── Care Blocks ── */
.care-block {
  padding: 20rpx;
  margin-bottom: 16rpx;
  background: #F0FDF7;
  border-radius: 14rpx;
  border-left: 4rpx solid #2D7D6E;
}
.care-subtitle {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A5A4E;
  margin-bottom: 8rpx;
}
.care-content {
  color: #4B5563;
  line-height: 1.7;
  margin-bottom: 8rpx;
}
.care-item {
  padding: 6rpx 0;
  color: #4B5563;
  line-height: 1.6;
}

/* ── Subsection Default ── */
.subsection-block {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.subsection-block:last-child { border-bottom: none; }
.subsection-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}
.subsection-content {
  color: #4B5563;
  line-height: 1.7;
  margin-bottom: 6rpx;
}
.subsection-item {
  padding: 4rpx 0;
  color: #6B7280;
  line-height: 1.6;
}

/* ── Section Items (fallback) ── */
.section-item {
  padding: 8rpx 0;
  color: #4B5563;
  line-height: 1.7;
}
.quote-text {
  display: block;
  padding: 16rpx 20rpx;
  background: #F9FAFB;
  border-left: 4rpx solid #D1D5DB;
  border-radius: 8rpx;
  color: #6B7280;
  font-style: italic;
}

/* ── Disclaimer ── */
.disclaimer {
  display: flex;
  gap: 16rpx;
  margin: 32rpx 32rpx 16rpx;
  padding: 24rpx;
  background: #FFFBEB;
  border: 1rpx solid #FDE68A;
  border-radius: 16rpx;
}
.disclaimer-icon { font-size: 36rpx; flex-shrink: 0; }
.disclaimer-text { flex: 1; }

/* ── Actions ── */
.report-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.04);
  padding: 16rpx 48rpx calc(16rpx + env(safe-area-inset-bottom));
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

/* ══════════════════════════════════════
   医疗科普报告样式
   ══════════════════════════════════════ */

/* ── Medical Header ── */
.med-header {
  position: relative;
  padding: 56rpx 40rpx 44rpx;
  background: linear-gradient(160deg, #EFF6FF 0%, #E0ECF5 30%, #F5F3F0 100%);
  overflow: hidden;
}
.med-header-bg {
  position: absolute;
  top: -60rpx;
  right: -30rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);
}
.med-header-content { position: relative; z-index: 1; }
.med-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(59,130,246,0.1);
  border-radius: 9999rpx;
  margin-bottom: 24rpx;
}
.med-badge-icon { font-size: 28rpx; }
.med-badge-text { font-size: 22rpx; color: #3B82F6; font-weight: 500; }
.med-title { font-size: 44rpx; font-weight: 800; color: #1F2937; }
.med-time { font-size: 24rpx; color: #9CA3AF; margin-top: 12rpx; }

/* ── Medical Sections ── */
.med-section {
  margin: 16rpx 32rpx;
  padding: 28rpx;
  border-radius: 20rpx;
}
.med-section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 20rpx;
}

/* Highlight variants */
.highlight-green { background: #F0FDF7; border: 1rpx solid #BBF7D0; }
.highlight-yellow { background: #FFFBEB; border: 1rpx solid #FDE68A; }
.highlight-red { background: #FFF5F5; border: 1rpx solid #FECACA; }
.highlight-herb { background: #FAFFF5; border: 1rpx solid #D9F0D1; }

.med-judgment { line-height: 1.8; color: #374151; }
.med-explain { padding-left: 16rpx; border-left: 4rpx solid #3B82F6; }

.med-info-row {
  display: flex;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}
.med-info-row:last-child { border-bottom: none; }
.med-info-key {
  width: 160rpx;
  font-size: 26rpx;
  color: #9CA3AF;
  flex-shrink: 0;
}
.med-info-val {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
  font-weight: 500;
}
.med-note { padding: 12rpx 16rpx; background: #FFF5F5; border-radius: 8rpx; }
.med-warning { padding: 12rpx 16rpx; background: #FEF2F2; border-radius: 8rpx; color: #DC2626; }

.med-list-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 10rpx 0;
  line-height: 1.6;
}
.med-list-dot { font-weight: 700; font-size: 28rpx; color: #2D7D6E; flex-shrink: 0; }
.med-list-dot.danger { color: #EF4444; }

/* ── TCM Blocks ── */
.tcm-block {
  padding: 18rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #D9F0D1;
}
.tcm-block:last-child { margin-bottom: 0; }
.tcm-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A5A4E;
  margin-bottom: 12rpx;
}
.tcm-row {
  display: flex;
  padding: 6rpx 0;
  font-size: 26rpx;
  line-height: 1.6;
}
.tcm-key { width: 80rpx; color: #9CA3AF; flex-shrink: 0; }
.tcm-val { flex: 1; color: #4B5563; }

/* ── Chat Panel ── */
.chat-fab {
  position: fixed;
  bottom: 140rpx;
  right: 32rpx;
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #3B82F6, #6366F1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(59,130,246,0.3);
  z-index: 10;
}
.chat-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60vh;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  z-index: 20;
  display: flex;
  flex-direction: column;
}
.chat-header {
  padding: 28rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F3F4F6;
}
.chat-body {
  flex: 1;
  padding: 16rpx 24rpx;
  overflow-y: auto;
}
.chat-msg { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.chat-msg.user { flex-direction: row-reverse; }
.chat-avatar {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #F3F4F6; display: flex; align-items: center; justify-content: center;
  font-size: 28rpx; flex-shrink: 0;
}
.chat-bubble {
  max-width: 75%;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  line-height: 1.6;
}
.chat-msg.user .chat-bubble { background: #3B82F6; color: #FFFFFF; border-bottom-right-radius: 4rpx; }
.chat-msg.assistant .chat-bubble { background: #F3F4F6; color: #374151; border-bottom-left-radius: 4rpx; }
.chat-bubble.typing { color: #9CA3AF; font-style: italic; }
.chat-footer {
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #F3F4F6;
  gap: 12rpx;
}
.chat-input {
  height: 72rpx;
  padding: 0 20rpx;
  background: #F3F4F6;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.chat-send-btn {
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #3B82F6;
  color: #FFFFFF;
  border-radius: 36rpx;
  font-size: 26rpx;
  border: none;
}

/* ══════════════════════════════════════
   新宠购买建议样式
   ══════════════════════════════════════ */

.np-header {
  position: relative;
  padding: 56rpx 40rpx 44rpx;
  background: linear-gradient(160deg, #FFF8F0 0%, #FDE8D0 30%, #FFF5EC 100%);
  overflow: hidden;
}
.np-header-bg {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245,158,11,0.08) 0%, transparent 70%);
}
.np-header-content { position: relative; z-index: 1; }
.np-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(245,158,11,0.12);
  border-radius: 9999rpx;
  margin-bottom: 24rpx;
}
.np-badge-icon { font-size: 28rpx; }
.np-badge-text { font-size: 22rpx; color: #D97706; font-weight: 500; }
.np-title { font-size: 44rpx; font-weight: 800; color: #1F2937; }
.np-time { font-size: 24rpx; color: #9CA3AF; margin-top: 12rpx; }

.np-summary {
  display: flex;
  gap: 16rpx;
  margin: -24rpx 32rpx 20rpx;
  padding: 28rpx;
  position: relative;
  z-index: 2;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.np-summary-icon { font-size: 40rpx; flex-shrink: 0; }
.np-summary-text { color: #4B5563; line-height: 1.7; flex: 1; }

.np-list { padding: 0 32rpx; }
.np-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  border: 1rpx solid #FDE68A;
  background: linear-gradient(135deg, #FFFFFF, #FFFDF5);
}
.np-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.np-card-type {
  padding: 4rpx 14rpx;
  background: #FEF3C7;
  border-radius: 6rpx;
  color: #92400E;
  font-weight: 500;
}
.np-card-score {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.np-score-num { font-size: 44rpx; font-weight: 800; color: #F59E0B; }
.np-score-label { font-size: 22rpx; color: #9CA3AF; }
.np-card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F2937;
  margin-bottom: 12rpx;
}
.np-card-tags { display: flex; gap: 12rpx; }
.np-tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  background: #F3F4F6;
  border-radius: 9999rpx;
  color: #6B7280;
}
.np-reasons { border-top: 1rpx solid #F3F4F6; padding-top: 16rpx; }
.np-reason {
  display: flex;
  gap: 8rpx;
  padding: 6rpx 0;
  color: #4B5563;
  line-height: 1.6;
}
.np-reason-dot { color: #F59E0B; font-weight: 700; }
.np-tips {
  display: flex;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #FFF8F0;
  border-radius: 10rpx;
}
.np-tips-icon { flex-shrink: 0; }
